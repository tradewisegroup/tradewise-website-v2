---
import MainLayout from '../layouts/MainLayout.astro';

const lastUpdated = '11 March 2026';
const companyName = 'TradeWise Group Pty Ltd';
const abn = 'ABN [INSERT ABN]';
const email = 'kate@tradewisegroup.au';
const phone = '1300 TRADEWISE';
const address = '[Insert Registered Address], Australia';
---

<MainLayout
    title="Privacy Policy | Tradewise Group"
    description="TradeWise Group Pty Ltd's Privacy Policy — how we collect, use, store, and protect your personal information in accordance with the Privacy Act 1988 (Cth) and the Australian Privacy Principles."
>

    <!-- Hero -->
    <section class="bg-tradewise-navy text-white py-16 md:py-20">
        <div class="max-w-4xl mx-auto px-6">
            <p class="text-momentum-amber text-sm font-semibold tracking-widest uppercase mb-4">Legal</p>
            <h1 class="font-heading text-4xl md:text-5xl font-bold mb-4 text-white">Privacy Policy</h1>
            <p class="text-white/60 text-sm">Last updated: {lastUpdated}</p>
        </div>
    </section>

    <!-- Content -->
    <section class="bg-concrete py-16 md:py-24">
        <div class="max-w-4xl mx-auto px-6">
            <div class="grid grid-cols-1 lg:grid-cols-4 gap-12">

                <!-- Sticky Table of Contents -->
                <aside class="lg:col-span-1">
                    <div class="bg-white rounded-xl p-6 shadow-sm sticky top-6">
                        <p class="text-xs font-semibold tracking-widest uppercase text-forge-black/40 mb-4">Contents</p>
                        <nav class="flex flex-col gap-2 text-sm">
                            {[
                                { label: '1. About This Policy',          href: '#about' },
                                { label: '2. Who We Are',                  href: '#who-we-are' },
                                { label: '3. What We Collect',            href: '#what-we-collect' },
                                { label: '4. How We Collect It',          href: '#how-we-collect' },
                                { label: '5. Why We Collect It',          href: '#why-we-collect' },
                                { label: '6. Use & Disclosure',           href: '#use-disclosure' },
                                { label: '7. Direct Marketing',           href: '#marketing' },
                                { label: '8. Overseas Disclosure',        href: '#overseas' },
                                { label: '9. Cookies & Tracking',         href: '#cookies' },
                                { label: '10. Data Security',             href: '#security' },
                                { label: '11. Retention',                 href: '#retention' },
                                { label: '12. Your Rights',               href: '#your-rights' },
                                { label: '13. Complaints',                href: '#complaints' },
                                { label: '14. Changes to This Policy',    href: '#changes' },
                                { label: '15. Contact Us',                href: '#contact' },
                            ].map(item => (
                                <a href={item.href} class="text-forge-black/55 hover:text-growth-teal transition-colors duration-150 leading-snug">
                                    {item.label}
                                </a>
                            ))}
                        </nav>
                    </div>
                </aside>

                <!-- Policy Body -->
                <div class="lg:col-span-3 flex flex-col gap-12">

                    <!-- Intro note -->
                    <div class="bg-momentum-amber/8 border border-momentum-amber/25 rounded-xl p-5">
                        <p class="text-forge-black/70 text-sm leading-relaxed">
                            <strong class="text-forge-black">Summary:</strong> TradeWise Group Pty Ltd is committed to protecting your personal information.
                            This policy explains what data we collect, why we collect it, how we use it, and your rights under
                            Australian law. We are bound by the <em>Privacy Act 1988</em> (Cth) and the <strong>Australian Privacy Principles (APPs)</strong>.
                            If you have any questions, contact us at <a href={`mailto:${email}`} class="text-growth-teal hover:underline">{email}</a>.
                        </p>
                    </div>

                    <!-- 1. About This Policy -->
                    <section id="about" class="scroll-mt-8">
                        <h2 class="font-heading text-2xl font-bold text-forge-black mb-4 pb-3 border-b border-forge-black/10">1. About This Policy</h2>
                        <div class="prose-content">
                            <p>This Privacy Policy describes how <strong>{companyName}</strong> ({abn}) ("<strong>TradeWise</strong>", "<strong>we</strong>", "<strong>us</strong>", "<strong>our</strong>") collects, holds, uses, and discloses personal information.</p>
                            <p>This policy applies to all personal information collected through our website (<strong>tradewisegroup.au</strong>), our business tools and calculators (including the Business Valuation Scorecard), our marketing activities, and our client engagement processes.</p>
                            <p>We are an Australian business operating primarily in Australia. This policy is prepared in accordance with:</p>
                            <ul>
                                <li>The <em>Privacy Act 1988</em> (Cth) and the <strong>Australian Privacy Principles (APPs)</strong></li>
                                <li>The <strong>Notifiable Data Breaches (NDB) scheme</strong> under Part IIIC of the Privacy Act</li>
                                <li>The <em>Spam Act 2003</em> (Cth) in relation to electronic communications</li>
                                <li>The <em>Do Not Call Register Act 2006</em> (Cth) in relation to telephone marketing</li>
                            </ul>
                            <p>Where our services are accessed by individuals in the United Kingdom or European Union, we also aim to meet the standards of the <strong>UK GDPR</strong> and <strong>EU GDPR</strong> respectively, to the extent reasonably practicable. However, our primary legal obligations are under Australian law.</p>
                        </div>
                    </section>

                    <!-- 2. Who We Are -->
                    <section id="who-we-are" class="scroll-mt-8">
                        <h2 class="font-heading text-2xl font-bold text-forge-black mb-4 pb-3 border-b border-forge-black/10">2. Who We Are</h2>
                        <div class="prose-content">
                            <p><strong>{companyName}</strong> is a business management services company providing outsourced operations, financial management, HR, systems, marketing, and exit planning services to trade business owners in Australia and internationally.</p>
                            <p>For the purposes of the Privacy Act 1988, TradeWise Group Pty Ltd is the <strong>APP entity</strong> responsible for personal information collected through our website and business activities.</p>
                            <div class="info-box">
                                <p><strong>Registered details:</strong></p>
                                <p>{companyName}<br />{abn}<br />{address}</p>
                                <p>Email: <a href={`mailto:${email}`}>{email}</a><br />Phone: {phone}</p>
                            </div>
                        </div>
                    </section>

                    <!-- 3. What We Collect -->
                    <section id="what-we-collect" class="scroll-mt-8">
                        <h2 class="font-heading text-2xl font-bold text-forge-black mb-4 pb-3 border-b border-forge-black/10">3. What Personal Information We Collect</h2>
                        <div class="prose-content">
                            <p>We collect personal information that is reasonably necessary for our business functions and activities. The types of personal information we may collect include:</p>

                            <h3>3.1 Identity & Contact Information</h3>
                            <ul>
                                <li>First name and last name</li>
                                <li>Email address</li>
                                <li>Phone number (including mobile)</li>
                                <li>Business name and trading name</li>
                                <li>Business address and state/location</li>
                            </ul>

                            <h3>3.2 Business Information</h3>
                            <ul>
                                <li>Trade type and industry (e.g. plumbing, electrical, HVAC)</li>
                                <li>Number of employees</li>
                                <li>Self-reported financial information (annual revenue, net profit, owner salary) provided voluntarily through our Business Valuation Scorecard tool</li>
                                <li>Self-reported business situation and goals</li>
                                <li>Scorecard responses and calculated scores</li>
                            </ul>

                            <h3>3.3 Technical & Usage Information</h3>
                            <ul>
                                <li>IP address and general geographic location</li>
                                <li>Browser type and version</li>
                                <li>Pages visited, time spent on pages, and navigation paths</li>
                                <li>Device type and operating system</li>
                                <li>Referring website or source</li>
                                <li>Cookie identifiers and session data (see Section 9)</li>
                            </ul>

                            <h3>3.4 Sensitive Information</h3>
                            <p>We do not intentionally collect sensitive information as defined under the Privacy Act (such as health, racial, or political information). If you voluntarily provide any sensitive information, we will handle it in accordance with APP 3.</p>

                            <h3>3.5 Financial Information</h3>
                            <p>The financial figures entered into our Business Valuation Scorecard (revenue, profit, salary) are used solely to calculate an indicative valuation estimate. This information is transmitted to our CRM (HubSpot) for the purpose of follow-up — please see Section 8 regarding overseas disclosure. We do not collect bank account details, credit card numbers, or tax file numbers.</p>
                        </div>
                    </section>

                    <!-- 4. How We Collect -->
                    <section id="how-we-collect" class="scroll-mt-8">
                        <h2 class="font-heading text-2xl font-bold text-forge-black mb-4 pb-3 border-b border-forge-black/10">4. How We Collect Personal Information</h2>
                        <div class="prose-content">
                            <p>We collect personal information in the following ways:</p>

                            <h3>4.1 Directly From You</h3>
                            <ul>
                                <li>When you complete our <strong>Business Valuation Scorecard</strong></li>
                                <li>When you submit an enquiry, contact form, or request a strategy call</li>
                                <li>When you book a meeting through our HubSpot scheduling tool</li>
                                <li>When you engage with us as a client, prospect, or partner</li>
                                <li>When you email, call, or otherwise communicate with us directly</li>
                                <li>When you subscribe to our email communications</li>
                            </ul>

                            <h3>4.2 Automatically Through Our Website</h3>
                            <ul>
                                <li>Through <strong>HubSpot analytics and tracking</strong> embedded on our website (see Section 9)</li>
                                <li>Through standard web server logs</li>
                                <li>Through cookies and similar tracking technologies</li>
                            </ul>

                            <h3>4.3 From Third Parties</h3>
                            <ul>
                                <li>From referral partners or introducers who refer clients to us</li>
                                <li>From publicly available sources (e.g. business registries, LinkedIn) where relevant to our engagement</li>
                            </ul>

                            <p>Where we collect personal information about an individual from a third party, we will take reasonable steps to notify that individual in accordance with APP 5.</p>

                            <h3>4.4 Anonymity Option</h3>
                            <p>In accordance with APP 2, where it is lawful and practicable, you may interact with us anonymously or using a pseudonym. However, if you wish to receive personalised services, a strategy call, or valuation results, we will need to collect your personal information.</p>
                        </div>
                    </section>

                    <!-- 5. Why We Collect -->
                    <section id="why-we-collect" class="scroll-mt-8">
                        <h2 class="font-heading text-2xl font-bold text-forge-black mb-4 pb-3 border-b border-forge-black/10">5. Why We Collect Personal Information</h2>
                        <div class="prose-content">
                            <p>We collect personal information only for purposes that are directly related to our business functions and activities. These purposes include:</p>
                            <ul>
                                <li>Providing and personalising our services to business owners</li>
                                <li>Responding to enquiries and scheduling strategy calls</li>
                                <li>Delivering Business Valuation Scorecard results and follow-up communications</li>
                                <li>Assessing whether our services are appropriate for your business</li>
                                <li>Managing client relationships and ongoing service engagements</li>
                                <li>Sending relevant marketing communications (with your consent or where we have a legitimate interest)</li>
                                <li>Improving and developing our website, tools, and services</li>
                                <li>Complying with our legal obligations under Australian law</li>
                                <li>Fraud prevention and security purposes</li>
                            </ul>
                            <p>We will not collect personal information unless it is reasonably necessary for one or more of the above purposes (APP 3.2).</p>
                        </div>
                    </section>

                    <!-- 6. Use & Disclosure -->
                    <section id="use-disclosure" class="scroll-mt-8">
                        <h2 class="font-heading text-2xl font-bold text-forge-black mb-4 pb-3 border-b border-forge-black/10">6. Use and Disclosure of Personal Information</h2>
                        <div class="prose-content">
                            <p>We will only use or disclose your personal information for the primary purpose for which it was collected, or for a secondary purpose if you would reasonably expect us to use it for that purpose, or with your consent (APP 6).</p>

                            <h3>6.1 We May Disclose Your Information To:</h3>
                            <ul>
                                <li><strong>HubSpot Inc.</strong> — our CRM and marketing automation platform (see Section 8 for overseas disclosure details)</li>
                                <li><strong>IT service providers</strong> — hosting, website infrastructure, and software vendors who support our operations</li>
                                <li><strong>Professional advisers</strong> — lawyers, accountants, and consultants where necessary for our business operations</li>
                                <li><strong>Regulatory and government bodies</strong> — where required or permitted by law (e.g. the Australian Taxation Office, ASIC)</li>
                                <li><strong>Prospective buyers or partners</strong> — only in the context of a business transaction involving TradeWise, and subject to confidentiality obligations</li>
                            </ul>

                            <h3>6.2 We Will Not:</h3>
                            <ul>
                                <li>Sell your personal information to third parties</li>
                                <li>Share your financial information with third parties for their own commercial purposes</li>
                                <li>Use your personal information for purposes unrelated to our services without your consent</li>
                            </ul>
                        </div>
                    </section>

                    <!-- 7. Direct Marketing -->
                    <section id="marketing" class="scroll-mt-8">
                        <h2 class="font-heading text-2xl font-bold text-forge-black mb-4 pb-3 border-b border-forge-black/10">7. Direct Marketing</h2>
                        <div class="prose-content">
                            <p>We may use your personal information to send you marketing communications about our services, tools, events, and resources where:</p>
                            <ul>
                                <li>You have provided your consent; or</li>
                                <li>We have collected your information in the course of a commercial relationship and the communication is related to similar products or services (consistent with APP 7 and the <em>Spam Act 2003</em>)</li>
                            </ul>
                            <p>All marketing emails sent by us will include a clear and functional <strong>unsubscribe mechanism</strong>. You may opt out of receiving marketing communications at any time by:</p>
                            <ul>
                                <li>Clicking "unsubscribe" in any email we send you</li>
                                <li>Emailing us at <a href={`mailto:${email}`}>{email}</a> with the subject "Unsubscribe"</li>
                            </ul>
                            <p>We will process all opt-out requests within <strong>5 business days</strong> in accordance with the <em>Spam Act 2003</em> (Cth). Opting out of marketing will not affect communications required to fulfil services you have requested.</p>
                        </div>
                    </section>

                    <!-- 8. Overseas Disclosure -->
                    <section id="overseas" class="scroll-mt-8">
                        <h2 class="font-heading text-2xl font-bold text-forge-black mb-4 pb-3 border-b border-forge-black/10">8. Cross-Border Disclosure of Personal Information</h2>
                        <div class="prose-content">
                            <p>In accordance with APP 8, we are required to disclose when your personal information may be transferred to overseas recipients.</p>

                            <h3>8.1 HubSpot Inc. (United States)</h3>
                            <p>We use <strong>HubSpot Inc.</strong>, a company headquartered in the United States, as our customer relationship management (CRM) and marketing automation platform. Personal information submitted through our website forms — including the Business Valuation Scorecard — is transmitted to and stored on HubSpot's servers, which may be located in the United States or other countries.</p>
                            <p>HubSpot participates in the <strong>EU–US Data Privacy Framework</strong> and maintains privacy protections consistent with international standards. You can review HubSpot's Privacy Policy at <strong>legal.hubspot.com/privacy-policy</strong>.</p>

                            <h3>8.2 Our Obligations Under APP 8</h3>
                            <p>Before disclosing your personal information to an overseas recipient, we take reasonable steps to ensure that the recipient does not breach the APPs in relation to your information. By submitting information through our website, you acknowledge that your personal information may be transferred to and stored overseas as described above.</p>

                            <h3>8.3 Other Overseas Transfers</h3>
                            <p>We may use other cloud-based software providers who store data on servers outside Australia (e.g. hosting services, analytics platforms). We take reasonable steps to ensure these providers maintain appropriate security standards.</p>
                        </div>
                    </section>

                    <!-- 9. Cookies -->
                    <section id="cookies" class="scroll-mt-8">
                        <h2 class="font-heading text-2xl font-bold text-forge-black mb-4 pb-3 border-b border-forge-black/10">9. Cookies and Tracking Technologies</h2>
                        <div class="prose-content">
                            <p>Our website uses cookies and similar tracking technologies to improve your experience and help us understand how visitors use our site.</p>

                            <h3>9.1 What Are Cookies?</h3>
                            <p>Cookies are small text files placed on your device by a website. They are widely used to make websites work efficiently and to provide information to the website owner.</p>

                            <h3>9.2 Cookies We Use</h3>
                            <ul>
                                <li><strong>HubSpot tracking cookies</strong> — used to track website visits, identify returning visitors, and associate form submissions with browsing activity. HubSpot uses the <strong>__hstc</strong>, <strong>hubspotutk</strong>, <strong>__hssc</strong>, and <strong>__hssrc</strong> cookies for this purpose.</li>
                                <li><strong>Essential cookies</strong> — necessary for the website to function correctly</li>
                                <li><strong>Analytics cookies</strong> — help us understand how visitors interact with our website (pages viewed, time on site, traffic source)</li>
                            </ul>

                            <h3>9.3 Managing Cookies</h3>
                            <p>You can control and manage cookies through your browser settings. You can choose to:</p>
                            <ul>
                                <li>Accept all cookies</li>
                                <li>Reject all non-essential cookies</li>
                                <li>Delete existing cookies</li>
                            </ul>
                            <p>Note that disabling cookies may affect the functionality of our website and tools. Instructions for managing cookies vary by browser — refer to your browser's help documentation for specific guidance.</p>

                            <h3>9.4 Do Not Track</h3>
                            <p>Some browsers send "Do Not Track" signals. Our website does not currently respond to these signals, however we respect your right to manage cookies as described above.</p>
                        </div>
                    </section>

                    <!-- 10. Security -->
                    <section id="security" class="scroll-mt-8">
                        <h2 class="font-heading text-2xl font-bold text-forge-black mb-4 pb-3 border-b border-forge-black/10">10. Security of Personal Information</h2>
                        <div class="prose-content">
                            <p>We take reasonable steps to protect the personal information we hold from misuse, interference, loss, and from unauthorised access, modification, or disclosure, in accordance with APP 11.</p>
                            <p>Our security measures include:</p>
                            <ul>
                                <li>Secure HTTPS encryption for all data transmitted through our website</li>
                                <li>Access controls and authentication requirements for internal systems</li>
                                <li>Use of reputable, security-certified third-party platforms (including HubSpot)</li>
                                <li>Regular review of our data handling practices</li>
                                <li>Staff awareness of privacy and data security obligations</li>
                            </ul>

                            <h3>10.1 Notifiable Data Breaches</h3>
                            <p>We are subject to the <strong>Notifiable Data Breaches (NDB) scheme</strong> under Part IIIC of the Privacy Act 1988. In the event of an eligible data breach — one that is likely to result in serious harm to affected individuals — we will:</p>
                            <ul>
                                <li>Notify the <strong>Office of the Australian Information Commissioner (OAIC)</strong> as soon as practicable</li>
                                <li>Notify affected individuals as required</li>
                                <li>Take immediate steps to contain the breach and prevent further harm</li>
                            </ul>

                            <p>While we implement reasonable security measures, no method of electronic data transmission or storage is completely secure. We cannot guarantee the absolute security of information transmitted to us online.</p>
                        </div>
                    </section>

                    <!-- 11. Retention -->
                    <section id="retention" class="scroll-mt-8">
                        <h2 class="font-heading text-2xl font-bold text-forge-black mb-4 pb-3 border-b border-forge-black/10">11. Retention of Personal Information</h2>
                        <div class="prose-content">
                            <p>We retain personal information for as long as reasonably necessary to fulfil the purposes for which it was collected, or as required by law.</p>
                            <ul>
                                <li><strong>Prospect information</strong> (e.g. scorecard submissions with no ongoing engagement) — retained for up to <strong>3 years</strong> for marketing and follow-up purposes, unless you request deletion earlier</li>
                                <li><strong>Client information</strong> — retained for a minimum of <strong>7 years</strong> following the conclusion of an engagement, as required by Australian tax and corporate law</li>
                                <li><strong>Website analytics data</strong> — retained in accordance with HubSpot's data retention policies</li>
                            </ul>
                            <p>When personal information is no longer required, we will take reasonable steps to destroy or de-identify it in accordance with APP 11.2.</p>
                        </div>
                    </section>

                    <!-- 12. Your Rights -->
                    <section id="your-rights" class="scroll-mt-8">
                        <h2 class="font-heading text-2xl font-bold text-forge-black mb-4 pb-3 border-b border-forge-black/10">12. Your Rights</h2>
                        <div class="prose-content">
                            <h3>12.1 Access (APP 12)</h3>
                            <p>You have the right to request access to the personal information we hold about you. We will respond to access requests within <strong>30 days</strong>. We will not charge a fee for making an access request, however we may charge a reasonable fee to cover the cost of providing access where the request is complex.</p>
                            <p>We may refuse access in limited circumstances permitted under APP 12.3 (e.g. where access would be unlawful, or unreasonably impact another individual's privacy). If we refuse access, we will provide written reasons.</p>

                            <h3>12.2 Correction (APP 13)</h3>
                            <p>If you believe that personal information we hold about you is inaccurate, out of date, incomplete, irrelevant, or misleading, you may request that we correct it. We will take reasonable steps to correct the information within <strong>30 days</strong> of your request.</p>

                            <h3>12.3 Deletion</h3>
                            <p>You may request that we delete personal information we hold about you. We will honour deletion requests where we are not legally required to retain the information. Please note that some information may need to be retained for legal, regulatory, or audit purposes.</p>

                            <h3>12.4 UK and EU Residents — Additional Rights</h3>
                            <p>If you are located in the United Kingdom or European Union, you may have additional rights under the UK GDPR or EU GDPR respectively, including:</p>
                            <ul>
                                <li>The right to data portability</li>
                                <li>The right to object to processing</li>
                                <li>The right to restrict processing</li>
                                <li>Rights in relation to automated decision-making</li>
                            </ul>
                            <p>Please contact us at <a href={`mailto:${email}`}>{email}</a> to exercise any of these rights. We will respond in good faith and in accordance with applicable law.</p>

                            <h3>12.5 How to Make a Request</h3>
                            <p>To exercise any of the above rights, please contact us at <a href={`mailto:${email}`}>{email}</a> with the subject line <strong>"Privacy Request"</strong>. We may need to verify your identity before processing your request.</p>
                        </div>
                    </section>

                    <!-- 13. Complaints -->
                    <section id="complaints" class="scroll-mt-8">
                        <h2 class="font-heading text-2xl font-bold text-forge-black mb-4 pb-3 border-b border-forge-black/10">13. Privacy Complaints</h2>
                        <div class="prose-content">
                            <p>If you believe we have interfered with your privacy or breached the Australian Privacy Principles, you have the right to make a complaint.</p>

                            <h3>13.1 Complain to Us First</h3>
                            <p>We ask that you contact us in the first instance to give us the opportunity to resolve your concern:</p>
                            <div class="info-box">
                                <p><strong>Privacy Officer</strong><br />{companyName}<br />Email: <a href={`mailto:${email}`}>{email}</a><br />Phone: {phone}</p>
                            </div>
                            <p>We will acknowledge your complaint within <strong>5 business days</strong> and aim to resolve it within <strong>30 days</strong>. If more time is required, we will notify you of the expected timeframe.</p>

                            <h3>13.2 Office of the Australian Information Commissioner (OAIC)</h3>
                            <p>If you are not satisfied with our response, you may lodge a complaint with the <strong>Office of the Australian Information Commissioner (OAIC)</strong>:</p>
                            <div class="info-box">
                                <p><strong>Office of the Australian Information Commissioner</strong><br />
                                Website: <strong>oaic.gov.au</strong><br />
                                Phone: <strong>1300 363 992</strong><br />
                                Post: GPO Box 5288, Sydney NSW 2001</p>
                            </div>

                            <h3>13.3 UK Residents</h3>
                            <p>UK residents may also lodge a complaint with the <strong>Information Commissioner's Office (ICO)</strong> at <strong>ico.org.uk</strong>.</p>

                            <h3>13.4 EU Residents</h3>
                            <p>EU residents may lodge a complaint with the relevant national <strong>Data Protection Authority (DPA)</strong> in their country of residence.</p>
                        </div>
                    </section>

                    <!-- 14. Changes -->
                    <section id="changes" class="scroll-mt-8">
                        <h2 class="font-heading text-2xl font-bold text-forge-black mb-4 pb-3 border-b border-forge-black/10">14. Changes to This Policy</h2>
                        <div class="prose-content">
                            <p>We may update this Privacy Policy from time to time to reflect changes in our practices, legal obligations, or for other operational reasons. When we make material changes, we will update the "Last updated" date at the top of this page.</p>
                            <p>We encourage you to review this policy periodically. Continued use of our website or services following any changes constitutes your acceptance of the updated policy.</p>
                            <p>For significant changes that materially affect how we handle your personal information, we will endeavour to notify you directly via email where we hold your contact details.</p>
                        </div>
                    </section>

                    <!-- 15. Contact -->
                    <section id="contact" class="scroll-mt-8">
                        <h2 class="font-heading text-2xl font-bold text-forge-black mb-4 pb-3 border-b border-forge-black/10">15. Contact Us</h2>
                        <div class="prose-content">
                            <p>For any questions, requests, or concerns regarding this Privacy Policy or the way we handle your personal information, please contact us:</p>
                            <div class="info-box">
                                <p><strong>{companyName}</strong><br />
                                {abn}<br />
                                {address}<br /><br />
                                Email: <a href={`mailto:${email}`}>{email}</a><br />
                                Phone: {phone}</p>
                            </div>
                            <p>We are committed to resolving privacy concerns promptly and transparently.</p>
                        </div>
                    </section>

                </div>
            </div>
        </div>
    </section>

</MainLayout>

<style>
    .prose-content {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        color: rgba(20, 28, 36, 0.70);
        font-size: 0.9375rem;
        line-height: 1.75;
