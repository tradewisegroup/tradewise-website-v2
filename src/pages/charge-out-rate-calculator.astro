---
import MainLayout from '../layouts/MainLayout.astro';
---

<!--
  ╔══════════════════════════════════════════════════════════════════╗
  ║  DEVELOPER NOTES — TRADEWISE GROUP CHARGE-OUT RATE CALCULATOR   ║
  ╠══════════════════════════════════════════════════════════════════╣
  ║                                                                  ║
  ║  WHERE TO UPDATE BRANDING                                        ║
  ║  All constants are at the very top of the <script is:inline>    ║
  ║  block. Change BRAND_PRIMARY, BRAND_ACCENT, BUSINESS_NAME,      ║
  ║  WEBSITE_URL and LOGO_URL there — nothing else needs touching.  ║
  ║                                                                  ║
  ║  HOW TO WIRE THE WEBHOOK                                         ║
  ║  Set LEAD_WEBHOOK_URL to your POST endpoint. Payload shape:      ║
  ║  { event: "lead_captured"|"cogs_report", leadData, resultsData } ║
  ║  All fetch() calls are wrapped in try/catch — the tool works     ║
  ║  even if the webhook is unreachable.                             ║
  ║                                                                  ║
  ║  HOW TO SWAP THE LOGO                                            ║
  ║  Set LOGO_URL to your hosted image path (e.g. '/images/logo.png')║
  ║  When non-empty an <img> is rendered; when empty the business    ║
  ║  name text is shown instead.                                     ║
  ║                                                                  ║
  ║  HOW TO EMBED ON YOUR SITE (iframe)                              ║
  ║  <iframe                                                         ║
  ║    src="https://tradewisegroup.au/charge-out-rate-calculator"    ║
  ║    width="100%" height="900" frameborder="0"                     ║
  ║    style="border:none;border-radius:12px;"                       ║
  ║    title="Charge-Out Rate Calculator | Tradewise Group"          ║
  ║  ></iframe>                                                      ║
  ║                                                                  ║
  ╚══════════════════════════════════════════════════════════════════╝
-->

<MainLayout
    title="Free Charge Out Rate Calculator for Australian Trades | Tradewise Group"
    description="Find out exactly what to charge per hour as an Australian trade business. Free calculator covering labour, on-costs, overheads and margin — personalised COGS report included."
>

<div id="calc-root">

  <!-- ══════════════════════ SCREEN 0 — LEAD GATE ══════════════════════ -->
  <div id="screen-0" class="cr-screen cr-active">
    <div class="cr-lead-hero">
      <div id="lead-logo-area"></div>
      <h1 class="cr-lead-heading">See the true cost of your team</h1>
      <p class="cr-lead-sub">Takes 3 minutes. Get a free personalised COGS report at the end.</p>
    </div>
    <div class="cr-card cr-lead-card">
      <form id="lead-form" novalidate>
        <div class="cr-grid-2">
          <div class="cr-field">
            <label class="cr-label" for="lf-first">First name <span class="cr-req">*</span></label>
            <input class="cr-input" id="lf-first" type="text" autocomplete="given-name" placeholder="Kate" />
            <span class="cr-err hidden">Required</span>
          </div>
          <div class="cr-field">
            <label class="cr-label" for="lf-last">Last name <span class="cr-req">*</span></label>
            <input class="cr-input" id="lf-last" type="text" autocomplete="family-name" placeholder="Walsh" />
            <span class="cr-err hidden">Required</span>
          </div>
        </div>
        <div class="cr-field">
          <label class="cr-label" for="lf-business">Business name <span class="cr-req">*</span></label>
          <input class="cr-input" id="lf-business" type="text" autocomplete="organization" placeholder="Smith Plumbing Pty Ltd" />
          <span class="cr-err hidden">Required</span>
        </div>
        <div class="cr-field">
          <label class="cr-label" for="lf-email">Email address <span class="cr-req">*</span></label>
          <input class="cr-input" id="lf-email" type="email" autocomplete="email" placeholder="kate@example.com.au" />
          <span class="cr-err hidden">Enter a valid email address</span>
        </div>
        <div class="cr-field">
          <label class="cr-label" for="lf-phone">Phone number <span class="cr-req">*</span></label>
          <input class="cr-input" id="lf-phone" type="tel" autocomplete="tel" placeholder="0400 000 000" />
          <span class="cr-err hidden">Required</span>
        </div>
        <div class="cr-grid-2">
          <div class="cr-field">
            <label class="cr-label" for="lf-state">State <span class="cr-req">*</span></label>
            <select class="cr-input cr-select" id="lf-state">
              <option value="">Select state…</option>
              <option>QLD</option><option>NSW</option><option>VIC</option><option>SA</option>
              <option>WA</option><option>TAS</option><option>ACT</option><option>NT</option>
            </select>
            <span class="cr-err hidden">Required</span>
          </div>
          <div class="cr-field">
            <label class="cr-label" for="lf-trade">Trade type</label>
            <select class="cr-input cr-select" id="lf-trade">
              <option value="">Select trade…</option>
              <option>Plumbing</option><option>Electrical</option><option>HVAC</option>
              <option>Carpentry</option><option>Concreting</option><option>Landscaping</option>
              <option>Painting</option><option>Other</option>
            </select>
          </div>
        </div>
        <button type="submit" class="cr-btn-primary cr-btn-full" id="lead-submit-btn">
          <span id="lead-submit-label">Start calculating →</span>
          <svg id="lead-spinner" class="cr-spinner hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="9" stroke-opacity="0.25"/><path d="M12 3a9 9 0 0 1 9 9"/></svg>
        </button>
      </form>
      <p class="cr-privacy">🔒 We don't spam. Your details are used only to send your free report.</p>
    </div>
  </div>

  <!-- ══════════════════════ PROGRESS BAR ══════════════════════ -->
  <div id="cr-progress" class="hidden">
    <div class="cr-prog-wrap">
      <div class="cr-prog-track">
        <div id="cr-prog-fill" class="cr-prog-fill" style="width:16.7%"></div>
      </div>
      <div class="cr-step-dots">
        <span class="cr-dot cr-dot-active"></span>
        <span class="cr-dot"></span>
        <span class="cr-dot"></span>
        <span class="cr-dot"></span>
        <span class="cr-dot"></span>
        <span class="cr-dot"></span>
      </div>
    </div>
    <p id="cr-step-label" class="cr-step-label">Step 1 of 6 — Worker type</p>
  </div>

  <!-- ══════════════════════ SCREEN 1 — WORKER TYPE ══════════════════════ -->
  <div id="screen-1" class="cr-screen hidden">
    <div class="cr-card">
      <h2 class="cr-card-h">Worker type</h2>
      <p class="cr-card-sub">Are you calculating costs for an employee or a subcontractor?</p>

      <div class="cr-toggle-group" id="worker-type-toggle">
        <button type="button" class="cr-tog cr-tog-on" data-value="employee">Employee</button>
        <button type="button" class="cr-tog" data-value="subcontractor">Subcontractor</button>
      </div>

      <div class="cr-field cr-mt-lg">
        <label class="cr-label" for="s1-state">State <span class="cr-hint-inline">(pre-filled from your details — update if needed)</span></label>
        <select class="cr-input cr-select" id="s1-state">
          <option value="">Select state…</option>
          <option>QLD</option><option>NSW</option><option>VIC</option><option>SA</option>
          <option>WA</option><option>TAS</option><option>ACT</option><option>NT</option>
        </select>
      </div>

      <div id="sub-flags" class="hidden cr-mt-lg">
        <div class="cr-infobox cr-ib-amber cr-mb">
          <p class="cr-ib-title">Subcontractor compliance flags</p>
          <p class="cr-ib-body">Answer honestly — getting these wrong can trigger ATO audits and back-payment obligations.</p>
        </div>

        <div class="cr-flag-block cr-mb">
          <p class="cr-label">Works more than 90 days per financial year with your business?</p>
          <div class="cr-toggle-group" id="flag-90days">
            <button type="button" class="cr-tog" data-value="yes">Yes</button>
            <button type="button" class="cr-tog cr-tog-on" data-value="no">No</button>
          </div>
          <div id="alert-90days" class="cr-infobox cr-ib-red cr-mt hidden">
            <p class="cr-ib-title">⚠ Payroll tax deeming may apply</p>
            <p class="cr-ib-body" id="alert-90days-text"></p>
          </div>
        </div>

        <div class="cr-flag-block">
          <p class="cr-label">Earns 80%+ of their income from your business for 52 consecutive weeks?</p>
          <div class="cr-toggle-group" id="flag-80pct">
            <button type="button" class="cr-tog" data-value="yes">Yes</button>
            <button type="button" class="cr-tog cr-tog-on" data-value="no">No</button>
          </div>
          <div id="alert-80pct" class="cr-infobox cr-ib-red cr-mt hidden">
            <p class="cr-ib-title">⚠ Superannuation guarantee may apply</p>
            <p class="cr-ib-body">If this contractor earns 80%+ of their income from you for 52+ consecutive weeks, you may be required to pay superannuation at 11.5% on their payments — regardless of their ABN or business structure.</p>
          </div>
        </div>
      </div>

      <div class="cr-nav">
        <div></div>
        <button type="button" class="cr-btn-primary" onclick="goToScreen(2)">Next →</button>
      </div>
    </div>
  </div>

  <!-- ══════════════════════ SCREEN 2 — BASE PAY ══════════════════════ -->
  <div id="screen-2" class="cr-screen hidden">
    <div class="cr-card">
      <h2 class="cr-card-h">Base pay</h2>

      <div id="s2-emp">
        <div class="cr-field">
          <label class="cr-label" for="s2-salary">Annual base salary ($)</label>
          <input class="cr-input" id="s2-salary" type="number" min="0" value="80000" />
        </div>
        <div class="cr-field cr-mt">
          <label class="cr-label" for="s2-hrs-wk">Billable hours per week</label>
          <input class="cr-input" id="s2-hrs-wk" type="number" min="1" max="80" value="38" />
        </div>
        <div class="cr-infobox cr-ib-blue cr-mt">
          <p class="cr-ib-title">ℹ Why 48 weeks?</p>
          <p class="cr-ib-body">This tool uses 48 working weeks (52 minus 4 weeks annual leave). Dividing salary by 52 weeks significantly underestimates real cost — it ignores leave loading and the overhead of unproductive weeks.</p>
        </div>
      </div>

      <div id="s2-sub" class="hidden">
        <div class="cr-field">
          <label class="cr-label" for="s2-sub-rate">Agreed hourly rate ex GST ($)</label>
          <input class="cr-input" id="s2-sub-rate" type="number" min="0" value="80" />
        </div>
        <div class="cr-field cr-mt">
          <label class="cr-label" for="s2-sub-hrs">Estimated hours per year</label>
          <input class="cr-input" id="s2-sub-hrs" type="number" min="0" value="1500" />
        </div>
        <div class="cr-infobox cr-ib-blue cr-mt">
          <p class="cr-ib-title">ℹ Full-time equivalent</p>
          <p class="cr-ib-body">~1,750 hours = full time equivalent. Adjust down if this contractor works part-year or part-week.</p>
        </div>
      </div>

      <div class="cr-nav">
        <button type="button" class="cr-btn-sec" onclick="goToScreen(1)">← Back</button>
        <button type="button" class="cr-btn-primary" onclick="goToScreen(3)">Next →</button>
      </div>
    </div>
  </div>

  <!-- ══════════════════════ SCREEN 3 — ON-COSTS ══════════════════════ -->
  <div id="screen-3" class="cr-screen hidden">
    <div class="cr-card">
      <h2 class="cr-card-h">Statutory on-costs</h2>

      <!-- Employee view -->
      <div id="s3-emp">
        <div class="cr-toggle-row cr-mb">
          <span class="cr-label" style="margin:0">Include payroll tax</span>
          <label class="cr-switch">
            <input type="checkbox" id="s3-pt-toggle" checked />
            <span class="cr-slider"></span>
          </label>
        </div>
        <div class="cr-table-wrap">
          <table class="cr-table">
            <thead><tr><th>Cost item</th><th>Annual $</th><th>% of salary</th></tr></thead>
            <tbody>
              <tr><td>Base salary</td><td id="s3-t-base">—</td><td>100%</td></tr>
              <tr><td>Superannuation (11.5%)</td><td id="s3-t-super">—</td><td>11.5%</td></tr>
              <tr id="s3-pt-row"><td id="s3-pt-label">Payroll tax</td><td id="s3-t-pt">—</td><td id="s3-t-pt-pct">—</td></tr>
              <tr><td>Annual leave provision (4 wks)</td><td id="s3-t-al">—</td><td>7.7%</td></tr>
              <tr><td>Long service leave (2.7%)</td><td id="s3-t-lsl">—</td><td>2.7%</td></tr>
              <tr><td>Productivity allowance (2%)</td><td id="s3-t-prod">—</td><td>2.0%</td></tr>
              <tr class="cr-tbl-total">
                <td><strong>Total true cost</strong></td>
                <td id="s3-t-total">—</td>
                <td id="s3-t-total-pct">—</td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="cr-infobox cr-ib-amber cr-mt">
          <p class="cr-ib-body" id="s3-callout-text">—</p>
        </div>
      </div>

      <!-- Subcontractor view -->
      <div id="s3-sub" class="hidden">
        <div class="cr-infobox cr-ib-blue cr-mb">
          <p class="cr-ib-title">Subcontractor obligations</p>
          <p class="cr-ib-body">Contract payments always apply. Super and payroll tax obligations depend on the compliance flags from Step 1.</p>
        </div>
        <div class="cr-table-wrap">
          <table class="cr-table">
            <thead><tr><th>Obligation</th><th>Applies?</th><th>Notes</th></tr></thead>
            <tbody>
              <tr><td>Contract payments</td><td>✅ Always</td><td>Agreed rate × hours</td></tr>
              <tr><td>Superannuation (11.5%)</td><td id="s3-sub-super">—</td><td>Triggered if 80%+ income rule applies</td></tr>
              <tr><td>Payroll tax</td><td id="s3-sub-pt">—</td><td id="s3-sub-pt-note">Triggered if 90-day rule applies</td></tr>
            </tbody>
          </table>
        </div>
        <div class="cr-mt">
          <p class="cr-label cr-mb-sm">State payroll tax rates (FY2025)</p>
          <div class="cr-table-wrap">
            <table class="cr-table cr-table-sm">
              <thead><tr><th>State</th><th>Rate</th><th>Annual threshold</th></tr></thead>
              <tbody>
                <tr><td>QLD</td><td>4.75%</td><td>$1,300,000</td></tr>
                <tr><td>NSW</td><td>5.30%</td><td>$1,200,000</td></tr>
                <tr><td>VIC</td><td>4.85%</td><td>$700,000</td></tr>
                <tr><td>SA</td><td>5.00%</td><td>$1,500,000</td></tr>
                <tr><td>WA</td><td>5.50%</td><td>$1,000,000</td></tr>
                <tr><td>TAS</td><td>6.50%</td><td>$1,250,000</td></tr>
                <tr><td>ACT</td><td>6.85%</td><td>$2,000,000</td></tr>
                <tr><td>NT</td><td>5.50%</td><td>$1,500,000</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="cr-nav">
        <button type="button" class="cr-btn-sec" onclick="goToScreen(2)">← Back</button>
        <button type="button" class="cr-btn-primary" onclick="goToScreen(4)">Next →</button>
      </div>
    </div>
  </div>

  <!-- ══════════════════════ SCREEN 4 — ALLOWANCES ══════════════════════ -->
  <div id="screen-4" class="cr-screen hidden">
    <div class="cr-card">
      <h2 class="cr-card-h">Allowances &amp; benefits</h2>
      <p class="cr-card-sub">Toggle on any that apply. Defaults are industry averages — adjust to your actual costs.</p>
      <div id="allowance-list"></div>
      <div class="cr-infobox cr-ib-blue cr-mt">
        <p class="cr-ib-title">🚗 FBT exemption update</p>
        <p class="cr-ib-body">Electric and eligible PHEV vehicles have been FBT-exempt since 1 April 2022. Talk to your accountant about whether your fleet qualifies — this can significantly reduce your effective fleet cost.</p>
      </div>
      <div class="cr-nav">
        <button type="button" class="cr-btn-sec" onclick="goToScreen(3)">← Back</button>
        <button type="button" class="cr-btn-primary" onclick="goToScreen(5)">Next →</button>
      </div>
    </div>
  </div>

  <!-- ══════════════════════ SCREEN 5 — OVERHEAD ══════════════════════ -->
  <div id="screen-5" class="cr-screen hidden">
    <div class="cr-card">
      <h2 class="cr-card-h">Business overhead</h2>

      <div class="cr-formula-box cr-mb">
        <div class="cr-formula-row">
          <span>Total below-the-line costs</span>
          <span id="f-costs">$0</span>
        </div>
        <div class="cr-formula-row cr-formula-div">
          <span>÷ (N staff × H hrs/wk × 48 wks)</span>
          <span id="f-hours">0 hrs</span>
        </div>
        <div class="cr-formula-row cr-formula-result">
          <span>= Overhead rate per hour</span>
          <strong id="f-rate">$0.00 / hr</strong>
        </div>
      </div>

      <p class="cr-section-label">Below-the-line costs (annual $)</p>
      <div id="overhead-inputs"></div>

      <p class="cr-section-label cr-mt-lg">Billable workforce</p>
      <div class="cr-grid-2">
        <div class="cr-field">
          <label class="cr-label" for="s5-staff">Number of billable staff</label>
          <input class="cr-input" id="s5-staff" type="number" min="1" value="2" />
        </div>
        <div class="cr-field">
          <label class="cr-label" for="s5-hrs">Billable hours per week each</label>
          <input class="cr-input" id="s5-hrs" type="number" min="1" max="80" value="38" />
        </div>
      </div>

      <p class="cr-section-label cr-mt-lg">Target margin</p>
      <div class="cr-field">
        <label class="cr-label" for="s5-margin">Target gross margin %</label>
        <input class="cr-input" id="s5-margin" type="number" min="1" max="90" value="30" />
        <p class="cr-hint">30% is typical for trades — covers SGA + net profit</p>
      </div>

      <div class="cr-infobox cr-ib-amber cr-mt">
        <p class="cr-ib-body">💡 Don't forget depreciation on tools, vehicles and equipment — and a salary for yourself if you do any admin work.</p>
      </div>

      <div class="cr-nav">
        <button type="button" class="cr-btn-sec" onclick="goToScreen(4)">← Back</button>
        <button type="button" class="cr-btn-primary" onclick="calcAndShow()">Calculate my rate →</button>
      </div>
    </div>
  </div>

  <!-- ══════════════════════ SCREEN 6 — RESULTS ══════════════════════ -->
  <div id="screen-results" class="cr-screen hidden">
    <div class="cr-card">
      <div class="cr-res-header">
        <h2 class="cr-card-h" style="margin-bottom:4px">Your results</h2>
        <p class="cr-card-sub" id="res-subtitle"></p>
      </div>

      <!-- 4 metric cards -->
      <div class="cr-metrics cr-mb">
        <div class="cr-metric">
          <p class="cr-metric-lbl">Annual salary / contract cost</p>
          <p class="cr-metric-val" id="m-salary">—</p>
        </div>
        <div class="cr-metric cr-metric-alert">
          <p class="cr-metric-lbl">True annual cost</p>
          <p class="cr-metric-val" id="m-true-cost">—</p>
          <p class="cr-metric-sub" id="m-true-pct">—</p>
        </div>
        <div class="cr-metric">
          <p class="cr-metric-lbl">True labour cost per hour</p>
          <p class="cr-metric-val" id="m-labour-hr">—</p>
        </div>
        <div class="cr-metric">
          <p class="cr-metric-lbl">Overhead recovered per hour</p>
          <p class="cr-metric-val" id="m-overhead-hr">—</p>
        </div>
      </div>

      <!-- Cost breakdown bar chart -->
      <div class="cr-chart-box cr-mb">
        <p class="cr-section-label">Annual cost breakdown</p>
        <canvas id="cost-chart"></canvas>
      </div>

      <!-- Rate build-up table -->
      <div class="cr-mb">
        <p class="cr-section-label">Charge-out rate build-up</p>
        <div class="cr-table-wrap">
          <table class="cr-table">
            <tbody>
              <tr><td>Labour cost per hour</td><td id="rt-labour">—</td></tr>
              <tr><td>+ Overhead per hour</td><td id="rt-overhead">—</td></tr>
              <tr><td>= Total cost per hour</td><td id="rt-cost">—</td></tr>
              <tr><td id="rt-margin-lbl">÷ (1 − 30%)</td><td id="rt-margin-val">—</td></tr>
              <tr class="cr-tbl-total"><td><strong>= Minimum charge-out rate</strong></td><td id="rt-rate"><strong>—</strong></td></tr>
            </tbody>
          </table>
        </div>
        <div class="cr-gst-box cr-mt">
          <span>Including GST (×1.1)</span>
          <span class="cr-gst-val" id="rt-gst">—</span>
        </div>
      </div>

      <!-- Loss callout -->
      <div class="cr-infobox cr-ib-amber cr-mb">
        <p class="cr-ib-body" id="res-loss">—</p>
      </div>

      <!-- CTA 1: COGS report -->
      <div class="cr-cta-card cr-mb">
        <div class="cr-cta-icon">📊</div>
        <div>
          <h3 class="cr-cta-h">Get your free personalised COGS report</h3>
          <p class="cr-cta-body" id="cta-cogs-body">We'll build out a full cost model for your business based on these numbers and send it to you.</p>
          <button type="button" class="cr-btn-primary cr-mt-sm" id="cogs-btn" onclick="sendCogsReport()">
            <span id="cogs-btn-lbl">Send my free COGS report</span>
            <svg id="cogs-spinner" class="cr-spinner hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="9" stroke-opacity="0.25"/><path d="M12 3a9 9 0 0 1 9 9"/></svg>
          </button>
          <div id="cogs-thanks" class="cr-infobox cr-ib-green cr-mt hidden">
            <p class="cr-ib-body">✅ Done! We'll send your COGS report to <strong id="cogs-email-confirm"></strong> shortly.</p>
          </div>
        </div>
      </div>

      <!-- CTA 2: Strategy call -->
      <div class="cr-cta-card cr-cta-card-sec cr-mb">
        <div class="cr-cta-icon">📞</div>
        <div>
          <h3 class="cr-cta-h">Want us to walk you through this?</h3>
          <p class="cr-cta-body">Book a free 30-minute strategy call with a TradeWise advisor. We'll show you exactly where your charge-out rates need to be.</p>
          <a id="booking-link" href="#" target="_blank" rel="noopener noreferrer" class="cr-btn-sec cr-btn-inline cr-mt-sm">Book a strategy call →</a>
        </div>
      </div>

      <div class="cr-text-center cr-mb">
        <button type="button" class="cr-link-btn" onclick="restartCalc()">← Start over with different numbers</button>
      </div>

      <p class="cr-calc-footer">© TradeWise Group · tradewisegroup.au · This tool is for indicative purposes only. Speak to your advisor before making pricing decisions.</p>
    </div>
  </div>

</div><!-- /calc-root -->

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>

<script is:inline>
// ─── BRANDING CONSTANTS (update these to rebrand) ─────────────────────────────
var BUSINESS_NAME    = 'Tradewise Group';
var WEBSITE_URL      = 'https://tradewisegroup.au';
var LOGO_URL         = ''; // developer: set to image path e.g. '/images/logo.png'
var BRAND_PRIMARY    = '#1E3A5F';
var BRAND_ACCENT     = '#D4820A';
var CONTACT_PAGE_URL = 'https://tradewisegroup.au/contact';
var BOOKING_URL      = 'https://calendly.com/tradewisegroup';
var LEAD_WEBHOOK_URL = ''; // developer: wire up POST endpoint
var LEAD_EMAIL       = ''; // developer: wire up fallback email

// ─── CALCULATOR CONSTANTS ─────────────────────────────────────────────────────
var SUPER_RATE        = 0.115;
var AL_WEEKS          = 4;
var WORK_WEEKS        = 48;
var LSL_RATE          = 0.027;
var PRODUCTIVITY_RATE = 0.02;

var PAYROLL_TAX = {
  QLD: { rate: 0.0475, threshold: 1300000 },
  NSW: { rate: 0.0530, threshold: 1200000 },
  VIC: { rate: 0.0485, threshold:  700000 },
  SA:  { rate: 0.0500, threshold: 1500000 },
  WA:  { rate: 0.0550, threshold: 1000000 },
  TAS: { rate: 0.0650, threshold: 1250000 },
  ACT: { rate: 0.0685, threshold: 2000000 },
  NT:  { rate: 0.0550, threshold: 1500000 },
};

var ALLOWANCE_DEFS = [
  { key: 'vehicle',  label: 'Vehicle / ute / fleet',        def: 20000, hint: 'Fuel, rego, insurance, maintenance, depreciation' },
  { key: 'phone',    label: 'Phone / mobile plan',           def: 1200,  hint: '~$100/month plan + handset amortised' },
  { key: 'uniform',  label: 'Uniforms / PPE',                def: 600,   hint: '2–3 sets workwear + PPE replacement' },
  { key: 'travel',   label: 'Travel allowance',              def: 2000,  hint: 'Overnight stays, remote site travel' },
  { key: 'other_mv', label: 'Other / motor vehicle benefit', def: 0,     hint: 'Novated lease FBT value, on-call allowance, tool of trade' },
];

var OVERHEAD_DEFS = [
  { key: 'rent',      label: 'Office rent',               def: 0     },
  { key: 'util',      label: 'Outgoings / utilities',     def: 1211  },
  { key: 'vehicles',  label: 'Business vehicles / fleet', def: 27669 },
  { key: 'phones',    label: 'Phones & internet',         def: 4244  },
  { key: 'insurance', label: 'Insurance',                 def: 0     },
  { key: 'software',  label: 'Software & subscriptions',  def: 0     },
  { key: 'marketing', label: 'Marketing & advertising',   def: 0     },
  { key: 'other',     label: 'Other overheads',           def: 17957 },
  { key: 'adminwage', label: 'Admin / office wages',      def: 60000 },
];

var STEP_NAMES = ['','Worker type','Base pay','On-costs','Allowances','Overhead','Results'];

// ─── STATE ────────────────────────────────────────────────────────────────────
var leadData    = {};
var calcData    = { workerType: 'employee', flag90: false, flag80: false, inclPt: true };
var resultsData = {};
var currentScreen = 0;
var costChart   = null;

// ─── INIT ─────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', function() {
  // Logo
  var logoArea = document.getElementById('lead-logo-area');
  if (LOGO_URL) {
    logoArea.innerHTML = '<img src="' + LOGO_URL + '" alt="' + BUSINESS_NAME + '" style="max-height:48px;margin-bottom:12px;" />';
  }

  // Booking link href
  document.getElementById('booking-link').href = BOOKING_URL;

  // Build dynamic sections
  buildAllowanceList();
  buildOverheadInputs();

  // Worker type toggle
  initToggleGroup('worker-type-toggle', function(val) {
    calcData.workerType = val;
    showEl('sub-flags', val === 'subcontractor');
  });

  // Subcontractor flags
  initToggleGroup('flag-90days', function(val) {
    calcData.flag90 = (val === 'yes');
    refreshSubFlags();
  });
  initToggleGroup('flag-80pct', function(val) {
    calcData.flag80 = (val === 'yes');
    refreshSubFlags();
  });

  // State change in screen 1
  el('s1-state').addEventListener('change', function() {
    calcData.state = this.value;
    refreshSubFlags();
    refreshOnCosts();
  });

  // PT toggle
  el('s3-pt-toggle').addEventListener('change', function() {
    calcData.inclPt = this.checked;
    refreshOnCosts();
  });

  // Live overhead formula
  el('overhead-inputs').addEventListener('input', refreshOverheadFormula);
  el('s5-staff').addEventListener('input', refreshOverheadFormula);
  el('s5-hrs').addEventListener('input', refreshOverheadFormula);

  // Lead form
  el('lead-form').addEventListener('submit', handleLeadSubmit);
});

// ─── HELPERS ──────────────────────────────────────────────────────────────────
function el(id) { return document.getElementById(id); }

function showEl(id, visible) {
  var e = el(id);
  if (!e) return;
  if (visible) e.classList.remove('hidden'); else e.classList.add('hidden');
}

function fmtD(n) { return '$' + Math.round(n).toLocaleString('en-AU'); }
function fmtHr(n) { return '$' + n.toFixed(2) + '/hr'; }
function pct(n)  { return Math.round(n * 100) + '%'; }

// ─── TOGGLE GROUPS ────────────────────────────────────────────────────────────
function initToggleGroup(groupId, onChange) {
  var btns = document.querySelectorAll('#' + groupId + ' .cr-tog');
  btns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      btns.forEach(function(b){ b.classList.remove('cr-tog-on'); });
      this.classList.add('cr-tog-on');
      onChange(this.dataset.value);
    });
  });
}

function getToggleValue(groupId) {
  var active = document.querySelector('#' + groupId + ' .cr-tog-on');
  return active ? active.dataset.value : null;
}

// ─── LEAD FORM ────────────────────────────────────────────────────────────────
async function handleLeadSubmit(e) {
  e.preventDefault();

  var fields = [
    { id: 'lf-first',    req: true,  email: false },
    { id: 'lf-last',     req: true,  email: false },
    { id: 'lf-business', req: true,  email: false },
    { id: 'lf-email',    req: true,  email: true  },
    { id: 'lf-phone',    req: true,  email: false },
    { id: 'lf-state',    req: true,  email: false },
  ];

  var valid = true;
  fields.forEach(function(f) {
    var input = el(f.id);
    var errEl = input.parentElement.querySelector('.cr-err');
    var val   = input.value.trim();
    var ok    = f.req ? !!val : true;
    if (ok && f.email && val) ok = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val);
    input.classList.toggle('cr-input-err', !ok);
    if (errEl) errEl.classList.toggle('hidden', ok);
    if (!ok) valid = false;
  });
  if (!valid) return;

  leadData = {
    firstName:    el('lf-first').value.trim(),
    lastName:     el('lf-last').value.trim(),
    businessName: el('lf-business').value.trim(),
    email:        el('lf-email').value.trim(),
    phone:        el('lf-phone').value.trim(),
    state:        el('lf-state').value,
    tradeType:    el('lf-trade').value,
  };

  calcData.state = leadData.state;

  var btn = el('lead-submit-btn');
  el('lead-submit-label').textContent = 'Submitting…';
  el('lead-spinner').classList.remove('hidden');
  btn.disabled = true;

  if (LEAD_WEBHOOK_URL) {
    try {
      await fetch(LEAD_WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ event: 'lead_captured', leadData: leadData }),
      });
    } catch(_) {}
  }

  el('lead-submit-label').textContent = 'Start calculating →';
  el('lead-spinner').classList.add('hidden');
  btn.disabled = false;

  // Pre-fill state in screen 1
  el('s1-state').value = leadData.state;

  // Update COGS email reference
  el('cta-cogs-body').textContent =
    "We'll build out a full cost model for your business based on these numbers and send it to " + leadData.email + ".";

  goToScreen(1);
}

// ─── NAVIGATION ───────────────────────────────────────────────────────────────
function goToScreen(n) {
  if (typeof n === 'number' && n > currentScreen) {
    if (!validateScreen(currentScreen)) return;
  }
  collectData(currentScreen);

  document.querySelectorAll('.cr-screen').forEach(function(s) {
    s.classList.add('hidden');
    s.classList.remove('cr-active');
  });

  var isResults = (n === 'results');
  var target = isResults ? el('screen-results') : el('screen-' + n);
  if (!target) return;
  target.classList.remove('hidden');
  target.classList.add('cr-active');
  currentScreen = n;

  // Progress bar
  var progStep = isResults ? 6 : n;
  if (progStep >= 1 && progStep <= 6) {
    showEl('cr-progress', true);
    el('cr-prog-fill').style.width = Math.round((progStep / 6) * 100) + '%';
    el('cr-step-label').textContent = 'Step ' + progStep + ' of 6' + (STEP_NAMES[progStep] ? ' — ' + STEP_NAMES[progStep] : '');
    // Update dots
    document.querySelectorAll('.cr-dot').forEach(function(dot, i) {
      dot.classList.remove('cr-dot-active', 'cr-dot-done');
      if (i + 1 < progStep) dot.classList.add('cr-dot-done');
      else if (i + 1 === progStep) dot.classList.add('cr-dot-active');
    });
  } else {
    showEl('cr-progress', false);
  }

  // Screen-specific refresh
  if (n === 2) refreshPayFields();
  if (n === 3) { refreshOnCostsUI(); refreshOnCosts(); }
  if (n === 5) refreshOverheadFormula();

  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function validateScreen(n) {
  if (n === 1 && !el('s1-state').value) {
    alert('Please select a state before continuing.');
    return false;
  }
  return true;
}

function collectData(n) {
  if (n === 1) {
    calcData.state = el('s1-state').value;
  }
  if (n === 2) {
    if (calcData.workerType === 'employee') {
      calcData.salary  = parseFloat(el('s2-salary').value)  || 80000;
      calcData.hrsWeek = parseFloat(el('s2-hrs-wk').value)  || 38;
    } else {
      calcData.subRate = parseFloat(el('s2-sub-rate').value) || 80;
      calcData.subHrs  = parseFloat(el('s2-sub-hrs').value)  || 1500;
    }
  }
  if (n === 4) {
    calcData.allowances = {};
    ALLOWANCE_DEFS.forEach(function(a) {
      var tog = el('atog-' + a.key);
      var inp = el('aval-' + a.key);
      calcData.allowances[a.key] = (tog && tog.checked) ? (parseFloat(inp.value) || 0) : 0;
    });
  }
  if (n === 5) {
    calcData.overheads = {};
    OVERHEAD_DEFS.forEach(function(o) {
      var inp = el('oh-' + o.key);
      calcData.overheads[o.key] = inp ? (parseFloat(inp.value) || 0) : 0;
    });
    calcData.numStaff  = parseInt(el('s5-staff').value)  || 2;
    calcData.billHrsWk = parseFloat(el('s5-hrs').value)  || 38;
    calcData.margin    = (parseFloat(el('s5-margin').value) || 30) / 100;
  }
}

function calcAndShow() {
  if (!validateScreen(5)) return;
  collectData(5);
  buildResults();
  goToScreen('results');
}

// ─── SCREEN 1: SUB FLAGS ──────────────────────────────────────────────────────
function refreshSubFlags() {
  var state = calcData.state || '';
  var pt    = PAYROLL_TAX[state];

  showEl('alert-90days', calcData.flag90 && !!pt);
  if (calcData.flag90 && pt) {
    el('alert-90days-text').textContent =
      'In ' + state + ', payroll tax applies at ' + (pt.rate * 100).toFixed(2) +
      '% on annual payroll above the $' + pt.threshold.toLocaleString('en-AU') +
      ' threshold. Contractors who exceed the 90-day rule may be deemed employees for payroll tax purposes.';
  }
  showEl('alert-80pct', calcData.flag80);
}

// ─── SCREEN 2: PAY FIELDS ─────────────────────────────────────────────────────
function refreshPayFields() {
  var isSub = calcData.workerType === 'subcontractor';
  showEl('s2-emp', !isSub);
  showEl('s2-sub', isSub);
}

// ─── SCREEN 3: ON-COSTS ───────────────────────────────────────────────────────
function refreshOnCostsUI() {
  var isSub = calcData.workerType === 'subcontractor';
  showEl('s3-emp', !isSub);
  showEl('s3-sub', isSub);
  if (isSub) {
    el('s3-sub-super').textContent = calcData.flag80 ? '⚠ May apply' : '✅ Not required';
    el('s3-sub-pt').textContent    = calcData.flag90 ? '⚠ May apply' : '✅ Not required';
    var state = calcData.state || '';
    var pt    = PAYROLL_TAX[state];
    el('s3-sub-pt-note').textContent = (calcData.flag90 && pt)
      ? state + ': ' + (pt.rate * 100).toFixed(2) + '% above $' + pt.threshold.toLocaleString('en-AU')
      : 'Triggered if 90-day rule applies';
  }
}

function refreshOnCosts() {
  var salary = parseFloat(el('s2-salary').value) || 80000;
  var state  = calcData.state || '';
  var pt     = PAYROLL_TAX[state];
  var inclPt = el('s3-pt-toggle').checked;

  var superAmt = salary * SUPER_RATE;
  var ptRate   = (pt && inclPt) ? pt.rate : 0;
  var ptAmt    = salary * ptRate;
  var alAmt    = salary * (AL_WEEKS / 52);
  var lslAmt   = salary * LSL_RATE;
  var prodAmt  = salary * PRODUCTIVITY_RATE;
  var total    = salary + superAmt + ptAmt + alAmt + lslAmt + prodAmt;
  var pctAbove = Math.round(((total / salary) - 1) * 100);

  el('s3-t-base').textContent  = fmtD(salary);
  el('s3-t-super').textContent = fmtD(superAmt);
  el('s3-t-al').textContent    = fmtD(alAmt);
  el('s3-t-lsl').textContent   = fmtD(lslAmt);
  el('s3-t-prod').textContent  = fmtD(prodAmt);
  el('s3-t-total').innerHTML   = '<strong>' + fmtD(total) + '</strong>';
  el('s3-t-total-pct').innerHTML = '<strong>' + Math.round((total / salary) * 100) + '%</strong>';

  var ptRow = el('s3-pt-row');
  if (inclPt && pt) {
    ptRow.style.display = '';
    el('s3-pt-label').textContent = 'Payroll tax (' + state + ' ' + (ptRate * 100).toFixed(2) + '%)';
    el('s3-t-pt').textContent     = fmtD(ptAmt);
    el('s3-t-pt-pct').textContent = (ptRate * 100).toFixed(2) + '%';
  } else {
    ptRow.style.display = 'none';
  }

  el('s3-callout-text').textContent =
    'Before allowances or overhead, this employee already costs ' + fmtD(total) +
    ' — ' + pctAbove + '% more than their salary.';
}

// ─── SCREEN 4: ALLOWANCES ─────────────────────────────────────────────────────
function buildAllowanceList() {
  var html = '';
  ALLOWANCE_DEFS.forEach(function(a) {
    html +=
      '<div class="cr-allow-row">' +
        '<label class="cr-switch">' +
          '<input type="checkbox" id="atog-' + a.key + '" onchange="toggleAllow(\'' + a.key + '\')" />' +
          '<span class="cr-slider"></span>' +
        '</label>' +
        '<div class="cr-allow-body">' +
          '<p class="cr-allow-label">' + a.label + '</p>' +
          '<p class="cr-hint">' + a.hint + '</p>' +
          '<div id="ainp-' + a.key + '" class="cr-allow-inp hidden">' +
            '<label class="cr-hint" style="display:block;margin-bottom:4px">Annual amount ($)</label>' +
            '<input class="cr-input cr-input-sm" id="aval-' + a.key + '" type="number" min="0" value="' + a.def + '" />' +
          '</div>' +
        '</div>' +
      '</div>';
  });
  el('allowance-list').innerHTML = html;
}

function toggleAllow(key) {
  var on = el('atog-' + key).checked;
  showEl('ainp-' + key, on);
}

// ─── SCREEN 5: OVERHEAD ───────────────────────────────────────────────────────
function buildOverheadInputs() {
  var html = '';
  OVERHEAD_DEFS.forEach(function(o) {
    html +=
      '<div class="cr-oh-row">' +
        '<label class="cr-label cr-oh-label" for="oh-' + o.key + '">' + o.label + '</label>' +
        '<div class="cr-oh-input">' +
          '<span class="cr-dollar-pre">$</span>' +
          '<input class="cr-input cr-input-right" id="oh-' + o.key + '" type="number" min="0" value="' + o.def + '" />' +
        '</div>' +
      '</div>';
  });
  el('overhead-inputs').innerHTML = html;
}

function refreshOverheadFormula() {
  var total = 0;
  OVERHEAD_DEFS.forEach(function(o) {
    var inp = el('oh-' + o.key);
    total += inp ? (parseFloat(inp.value) || 0) : 0;
  });
  var staff   = parseInt(el('s5-staff').value)  || 2;
  var hrs     = parseFloat(el('s5-hrs').value)  || 38;
  var totHrs  = staff * hrs * WORK_WEEKS;
  var rate    = totHrs > 0 ? total / totHrs : 0;
  el('f-costs').textContent = fmtD(total);
  el('f-hours').textContent = totHrs.toLocaleString('en-AU') + ' hrs';
  el('f-rate').textContent  = '$' + rate.toFixed(2) + '/hr';
}

// ─── CALCULATION ──────────────────────────────────────────────────────────────
function buildResults() {
  var isSub   = calcData.workerType === 'subcontractor';
  var state   = calcData.state || '';
  var pt      = PAYROLL_TAX[state];
  var margin  = calcData.margin || 0.30;

  // ---- Labour costs ----
  var salary, superAmt, ptAmt, alAmt, lslAmt, prodAmt, allowTotal, trueCost, labourHrs;

  if (!isSub) {
    salary     = calcData.salary  || 80000;
    labourHrs  = (calcData.hrsWeek || 38) * WORK_WEEKS;
    var ptRate = (pt && calcData.inclPt) ? pt.rate : 0;
    superAmt   = salary * SUPER_RATE;
    ptAmt      = salary * ptRate;
    alAmt      = salary * (AL_WEEKS / 52);
    lslAmt     = salary * LSL_RATE;
    prodAmt    = salary * PRODUCTIVITY_RATE;
    allowTotal = 0;
    if (calcData.allowances) {
      ALLOWANCE_DEFS.forEach(function(a) { allowTotal += calcData.allowances[a.key] || 0; });
    }
    trueCost = salary + superAmt + ptAmt + alAmt + lslAmt + prodAmt + allowTotal;
  } else {
    salary    = (calcData.subRate || 80) * (calcData.subHrs || 1500);
    labourHrs = calcData.subHrs || 1500;
    superAmt  = calcData.flag80 ? salary * SUPER_RATE : 0;
    ptAmt     = (calcData.flag90 && pt) ? salary * pt.rate : 0;
    alAmt     = 0; lslAmt = 0; prodAmt = 0; allowTotal = 0;
    trueCost  = salary + superAmt + ptAmt;
  }

  // ---- Overhead ----
  var totalOverhead = 0;
  if (calcData.overheads) {
    OVERHEAD_DEFS.forEach(function(o) { totalOverhead += calcData.overheads[o.key] || 0; });
  }
  var numStaff    = calcData.numStaff  || 2;
  var billHrsWk   = calcData.billHrsWk || 38;
  var overheadHrs = numStaff * billHrsWk * WORK_WEEKS;
  var overheadHr  = overheadHrs > 0 ? totalOverhead / overheadHrs : 0;
  var labourHr    = labourHrs  > 0 ? trueCost      / labourHrs    : 0;
  var totalHr     = labourHr + overheadHr;
  var minRate     = margin < 1 ? totalHr / (1 - margin) : totalHr;
  var gstRate     = minRate * 1.1;

  // Base salary ÷ hours — what they'd recover if pricing on salary alone
  var baseSalaryHr    = labourHrs > 0 ? salary / labourHrs : 0;
  var shortfallHr     = minRate - baseSalaryHr;
  var annualShortfall = shortfallHr * labourHrs;

  // ---- Store results ----
  resultsData = {
    salary, superAmt, ptAmt, alAmt, lslAmt, prodAmt, allowTotal,
    trueCost, labourHrs, labourHr, overheadHr, totalHr,
    margin, minRate, gstRate, baseSalaryHr, shortfallHr, annualShortfall,
    totalOverhead, workerType: calcData.workerType, state,
  };

  // ---- Render ----
  var bizName = leadData.businessName || '';
  el('res-subtitle').textContent = bizName
    ? bizName + ' · ' + (leadData.tradeType || calcData.workerType) + ' · ' + state
    : (leadData.tradeType || calcData.workerType) + ' · ' + state;

  el('m-salary').textContent       = fmtD(salary);
  el('m-true-cost').textContent    = fmtD(trueCost);
  el('m-true-pct').textContent     = '+' + Math.round(((trueCost / salary) - 1) * 100) + '% above salary';
  el('m-labour-hr').textContent    = fmtHr(labourHr);
  el('m-overhead-hr').textContent  = fmtHr(overheadHr);

  el('rt-labour').textContent    = fmtHr(labourHr);
  el('rt-overhead').textContent  = fmtHr(overheadHr);
  el('rt-cost').textContent      = fmtHr(totalHr);
  el('rt-margin-lbl').textContent = '÷ (1 − ' + Math.round(margin * 100) + '%)';
  el('rt-margin-val').textContent = '÷ ' + (1 - margin).toFixed(2);
  el('rt-rate').innerHTML        = '<strong>' + fmtHr(minRate) + '</strong>';
  el('rt-gst').textContent       = fmtHr(gstRate);

  el('res-loss').textContent =
    'If you\'re charging at base salary rate only (' + fmtHr(baseSalaryHr) + '), you\'re short ' +
    fmtHr(shortfallHr) + ' per hour — that\'s ' + fmtD(annualShortfall) + '/year left on the table for this one worker.';

  // ---- Chart ----
  renderChart(salary, superAmt, ptAmt, alAmt + lslAmt, allowTotal, prodAmt);
}

function renderChart(base, sup, tax, leave, allowances, prod) {
  var canvas = el('cost-chart');
  if (costChart) { costChart.destroy(); costChart = null; }

  var labels = ['Base salary','Superannuation','Payroll tax','Leave provisions','Allowances','Productivity'];
  var values = [base, sup, tax, leave, allowances, prod];
  var colors = ['#185FA5','#1D9E75','#BA7517','#D85A30','#7F77DD','#888780'];

  // Filter zero items
  var filteredLabels = [], filteredValues = [], filteredColors = [];
  values.forEach(function(v, i) {
    if (v > 0) {
      filteredLabels.push(labels[i]);
      filteredValues.push(v);
      filteredColors.push(colors[i]);
    }
  });

  costChart = new Chart(canvas, {
    type: 'bar',
    data: {
      labels: filteredLabels,
      datasets: [{
        data: filteredValues,
        backgroundColor: filteredColors,
        borderRadius: 4,
        borderSkipped: false,
      }]
    },
    options: {
      indexAxis: 'y',
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: function(ctx) { return ' ' + fmtD(ctx.raw); }
          }
        }
      },
      scales: {
        x: {
          ticks: {
            callback: function(v) { return '$' + (v/1000).toFixed(0) + 'k'; },
            font: { size: 11 },
          },
          grid: { color: 'rgba(0,0,0,0.06)' }
        },
        y: {
          ticks: { font: { size: 12 } },
          grid: { display: false }
        }
      }
    }
  });
  // Set canvas height based on item count
  canvas.style.height = Math.max(180, filteredLabels.length * 44) + 'px';
}

// ─── COGS REPORT ─────────────────────────────────────────────────────────────
async function sendCogsReport() {
  var btn  = el('cogs-btn');
  var lbl  = el('cogs-btn-lbl');
  var spin = el('cogs-spinner');
  btn.disabled = true;
  lbl.textContent = 'Sending…';
  spin.classList.remove('hidden');

  if (LEAD_WEBHOOK_URL) {
    try {
      await fetch(LEAD_WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ event: 'cogs_report', leadData: leadData, resultsData: resultsData }),
      });
    } catch(_) {}
  }

  // Open contact page in new tab
  if (CONTACT_PAGE_URL) window.open(CONTACT_PAGE_URL, '_blank', 'noopener,noreferrer');

  lbl.textContent = 'Sent!';
  spin.classList.add('hidden');
  showEl('cogs-thanks', true);
  el('cogs-email-confirm').textContent = leadData.email || 'your email';
  btn.disabled = true;
}

// ─── RESTART ─────────────────────────────────────────────────────────────────
function restartCalc() {
  leadData = {}; calcData = { workerType: 'employee', flag90: false, flag80: false, inclPt: true }; resultsData = {};
  currentScreen = 0;
  el('lead-form').reset();
  document.querySelectorAll('.cr-input-err').forEach(function(e){ e.classList.remove('cr-input-err'); });
  document.querySelectorAll('.cr-err').forEach(function(e){ e.classList.add('hidden'); });
  document.querySelectorAll('.cr-screen').forEach(function(s){ s.classList.add('hidden'); s.classList.remove('cr-active'); });
  el('screen-0').classList.remove('hidden');
  el('screen-0').classList.add('cr-active');
  showEl('cr-progress', false);
  showEl('cogs-thanks', false);
  el('cogs-btn').disabled = false;
  el('cogs-btn-lbl').textContent = 'Send my free COGS report';
  if (costChart) { costChart.destroy(); costChart = null; }
  window.scrollTo({ top: 0 });
}
</script>

