---
import MainLayout from '../layouts/MainLayout.astro';

const engineSteps = [
    {
        number: '01',
        title: 'Discovery Call & Health Check',
        duration: '30 minutes',
        description: 'Every engagement starts with a genuine conversation. We spend 30 minutes understanding your business and run a live Business Health Check.',
        whatYouGet: 'A live health check score and focus recommendations that you can walk away with instantly.',
        icon: 'phone',
    },
    {
        number: '02',
        title: 'The Proposal',
        duration: '1–2 weeks',
        description: 'We don\'t guess; we prescribe. Based on your Health Check, we come back with a tailored proposal and present exactly how we will take over your admin, finance, HR, and systems.',
        whatYouGet: 'A clear, no-surprises roadmap of how we will build your engine room.',
        icon: 'document',
    },
    {
        number: '03',
        title: 'Onboarding',
        duration: '14 Days',
        description: 'This is where the work begins. We integrate our team into your business, clean up immediate messes, and establish the foundational systems needed for growth.',
        whatYouGet: 'Immediate relief from backend chaos and a dedicated team embedded in your operations.',
        icon: 'rocket',
    },
    {
        number: '04',
        title: '90-Day Planning & Valuation',
        duration: 'Half Day',
        description: 'We sit down together to build your strategic roadmap. This includes your first 90-day action plan and a detailed business valuation.',
        note: 'Valuations are for internal strategic purposes and do not constitute formal financial advice.',
        whatYouGet: 'A clear 90-day execution plan and a baseline valuation of your business asset.',
        icon: 'target',
    },
    {
        number: '05',
        title: 'Ongoing Execution & Review',
        duration: 'Ongoing',
        description: 'We don\'t just plan; we execute. Your Tradewise team handles the daily operations while keeping you informed and in control.',
        whatYouGet: 'Weekly updates, monthly performance reports, quarterly 90-day strategy sessions, and comprehensive annual reviews.',
        icon: 'chart',
        highlight: true,
    },
];

const exitSteps = [
    {
        number: '01',
        title: 'Discovery Call & Exit Readiness',
        duration: '30 minutes',
        description: 'We explore your ultimate goal — whether that\'s walking away completely or retaining a passive income stream. We run a live exit planning health check and goal analysis.',
        whatYouGet: 'A live exit readiness score and focus recommendations that you can walk away with instantly.',
        icon: 'phone',
    },
    {
        number: '02',
        title: 'The Proposal & Intent',
        duration: '1–2 weeks',
        description: 'We present a reality check on your current business value and walk you through our exit models. We come back with a proposal that includes a potential high-level offer of intent.',
        whatYouGet: 'A clear presentation of your exit options and a high-level letter of intent outlining the proposed structure.',
        icon: 'document',
    },
    {
        number: '03',
        title: 'Onboarding',
        duration: '14 Days',
        description: 'Once we agree on the right exit strategy, we formalise the partnership and begin the integration process to prepare the business for transition.',
        whatYouGet: 'A structured onboarding process to align our teams and begin the value maximisation journey.',
        icon: 'rocket',
    },
    {
        number: '04',
        title: '90-Day Planning, Valuation & Legal',
        duration: 'Half Day',
        description: 'We build the roadmap to your exit. This includes your first 90-day action plan, a detailed formal valuation, and the initiation of the legal pathway required for the transition.',
        whatYouGet: 'A clear 90-day execution plan, a detailed valuation, and the legal framework for your exit.',
        icon: 'scales',
    },
    {
        number: '05',
        title: 'Ongoing Execution & Transition',
        duration: 'Ongoing',
        description: 'We execute the strategy to maximise your business value and manage the transition process according to the agreed timeline.',
        whatYouGet: 'Weekly updates, monthly reports, quarterly 90-day strategy sessions, annual reviews, and strict tracking against your goal timelines.',
        icon: 'chart',
        highlight: true,
    },
];
---

<MainLayout
    title="How We Work | Tradewise Group"
    description="Two distinct paths for two distinct goals — Business Engine for growth, Exit Planning for transition. Choose the path that fits your business today."
>

    <!-- Header -->
    <section class="bg-tradewise-navy text-white py-20 md:py-28">
        <div class="max-w-7xl mx-auto px-6">
            <div class="max-w-3xl">
                <p class="text-momentum-amber text-sm font-semibold tracking-widest uppercase mb-6">
                    The Process
                </p>
                <h1 class="font-heading text-4xl md:text-5xl font-bold mb-6 text-growth-teal">
                    How We Work
                </h1>
                <p class="text-white/70 text-lg leading-relaxed">
                    Every trade business is at a different stage. Some owners need an "engine room" to take
                    over the daily chaos so they can grow. Others have built a strong business and are looking
                    for a structured path to exit. Because your goals are unique, we don't force you into a
                    one-size-fits-all process. Choose the path that aligns with where your business is today.
                </p>
            </div>
        </div>
    </section>

    <!-- Path selector pills (mobile sticky) -->
    <div class="lg:hidden sticky top-0 z-40 bg-white border-b border-forge-black/10 shadow-sm">
        <div class="flex">
            <a href="#business-engine" class="flex-1 py-3 text-center text-sm font-semibold text-growth-teal border-b-2 border-growth-teal">
                Business Engine
            </a>
            <a href="#exit-planning" class="flex-1 py-3 text-center text-sm font-semibold text-forge-black/50 border-b-2 border-transparent">
                Exit Planning
            </a>
        </div>
    </div>

    <!-- Two-path layout -->
    <section class="bg-concrete">
        <div class="max-w-7xl mx-auto px-6 py-16 md:py-24">

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 xl:gap-12 items-start">

                <!-- ===== COLUMN 1: BUSINESS ENGINE ===== -->
                <div id="business-engine" class="flex flex-col rounded-2xl overflow-hidden shadow-lg border border-growth-teal/20">

                    <!-- Column header -->
                    <div class="bg-growth-teal text-white px-8 py-8">
                        <div class="flex items-center gap-3 mb-3">
                            <!-- Engine icon -->
                            <div class="w-10 h-10 rounded-xl bg-white/15 flex items-center justify-center shrink-0">
                                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                            </div>
                            <h2 class="font-heading text-2xl font-bold">Business Engine</h2>
                        </div>
                        <p class="text-white/75 text-sm leading-relaxed">
                            We build the backend so you can build the business.
                        </p>
                    </div>

                    <!-- Steps -->
                    <div class="bg-white flex flex-col flex-1">
                        {engineSteps.map((step, i) => (
                            <div class={`px-8 py-7 flex gap-5 border-b border-forge-black/8 last:border-0 ${step.highlight ? 'bg-growth-teal/5' : ''}`}>

                                <!-- Step number + icon -->
                                <div class="flex flex-col items-center gap-2 shrink-0">
                                    <div class={`w-10 h-10 rounded-full flex items-center justify-center shrink-0 ${step.highlight ? 'bg-growth-teal text-white' : 'bg-growth-teal/10 text-growth-teal'}`}>
                                        {step.icon === 'phone' && (
                                            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                            </svg>
                                        )}
                                        {step.icon === 'document' && (
                                            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                            </svg>
                                        )}
                                        {step.icon === 'rocket' && (
                                            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                                            </svg>
                                        )}
                                        {step.icon === 'target' && (
                                            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                                                <circle cx="12" cy="12" r="6" stroke="currentColor" stroke-width="2"/>
                                                <circle cx="12" cy="12" r="2" stroke="currentColor" stroke-width="2"/>
                                            </svg>
                                        )}
                                        {step.icon === 'chart' && (
                                            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                                            </svg>
                                        )}
                                    </div>
                                    {i < engineSteps.length - 1 && (
                                        <div class="w-px flex-1 min-h-6 bg-growth-teal/20"></div>
                                    )}
                                </div>

                                <!-- Content -->
                                <div class="flex-1 min-w-0 pb-1">
                                    <div class="flex items-baseline gap-2 mb-1 flex-wrap">
                                        <span class="text-xs font-bold tracking-widest text-growth-teal uppercase">
                                            Step {step.number}
                                        </span>
                                        <span class="text-xs text-forge-black/35 font-medium">— {step.duration}</span>
                                    </div>
                                    <h3 class="font-heading font-bold text-forge-black text-base mb-2 leading-snug">
                                        {step.title}
                                    </h3>
                                    <p class="text-forge-black/60 text-sm leading-relaxed mb-3">
                                        {step.description}
                                    </p>
                                    {step.note && (
                                        <p class="text-forge-black/40 text-xs italic mb-3">
                                            Note: {step.note}
                                        </p>
                                    )}
                                    <div class="flex items-start gap-2">
                                        <span class="text-growth-teal mt-0.5 shrink-0">
                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                                            </svg>
                                        </span>
                                        <p class="text-forge-black/70 text-xs leading-relaxed">
                                            <span class="font-semibold">What You Get:</span> {step.whatYouGet}
                                        </p>
                                    </div>
                                </div>
                            </div>
                        ))}

                        <!-- CTA -->
                        <div class="px-8 py-7 bg-growth-teal/5 border-t border-growth-teal/15">
                            <a
                                href="/business-engine"
                                class="flex items-center justify-center gap-2 w-full bg-growth-teal text-white font-semibold text-sm px-6 py-3.5 rounded-lg hover:brightness-110 transition-all duration-200 group"
                            >
                                Explore Business Engine Details
                                <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- ===== COLUMN 2: EXIT PLANNING ===== -->
                <div id="exit-planning" class="flex flex-col rounded-2xl overflow-hidden shadow-lg border border-tradewise-navy/20">

                    <!-- Column header -->
                    <div class="bg-tradewise-navy text-white px-8 py-8">
                        <div class="flex items-center gap-3 mb-3">
                            <!-- Exit icon -->
                            <div class="w-10 h-10 rounded-xl bg-white/15 flex items-center justify-center shrink-0">
                                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                                </svg>
                            </div>
                            <h2 class="font-heading text-2xl font-bold">Exit Planning</h2>
                        </div>
                        <p class="text-white/75 text-sm leading-relaxed">
                            Maximise value and plan your transition out.
                        </p>
                    </div>

                    <!-- Steps -->
                    <div class="bg-white flex flex-col flex-1">
                        {exitSteps.map((step, i) => (
                            <div class={`px-8 py-7 flex gap-5 border-b border-forge-black/8 last:border-0 ${step.highlight ? 'bg-tradewise-navy/5' : ''}`}>

                                <!-- Step number + icon -->
                                <div class="flex flex-col items-center gap-2 shrink-0">
                                    <div class={`w-10 h-10 rounded-full flex items-center justify-center shrink-0 ${step.highlight ? 'bg-tradewise-navy text-white' : 'bg-tradewise-navy/10 text-tradewise-navy'}`}>
                                        {step.icon === 'phone' && (
                                            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                            </svg>
                                        )}
                                        {step.icon === 'document' && (
                                            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                            </svg>
                                        )}
                                        {step.icon === 'rocket' && (
                                            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                                            </svg>
                                        )}
                                        {step.icon === 'scales' && (
                                            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
                                            </svg>
                                        )}
                                        {step.icon === 'chart' && (
                                            <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                                            </svg>
                                        )}
                                    </div>
                                    {i < exitSteps.length - 1 && (
                                        <div class="w-px flex-1 min-h-6 bg-tradewise-navy/20"></div>
                                    )}
                                </div>

                                <!-- Content -->
                                <div class="flex-1 min-w-0 pb-1">
                                    <div class="flex items-baseline gap-2 mb-1 flex-wrap">
                                        <span class="text-xs font-bold tracking-widest text-tradewise-navy uppercase">
                                            Step {step.number}
                                        </span>
                                        <span class="text-xs text-forge-black/35 font-medium">— {step.duration}</span>
                                    </div>
                                    <h3 class="font-heading font-bold text-forge-black text-base mb-2 leading-snug">
                                        {step.title}
                                    </h3>
                                    <p class="text-forge-black/60 text-sm leading-relaxed mb-3">
                                        {step.description}
                                    </p>
                                    <div class="flex items-start gap-2">
                                        <span class="text-tradewise-navy mt-0.5 shrink-0">
                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                                            </svg>
                                        </span>
                                        <p class="text-forge-black/70 text-xs leading-relaxed">
                                            <span class="font-semibold">What You Get:</span> {step.whatYouGet}
                                        </p>
                                    </div>
                                </div>
                            </div>
                        ))}

                        <!-- CTA -->
                        <div class="px-8 py-7 bg-tradewise-navy/5 border-t border-tradewise-navy/15">
                            <a
                                href="/exit-planning"
                                class="flex items-center justify-center gap-2 w-full bg-tradewise-navy text-white font-semibold text-sm px-6 py-3.5 rounded-lg hover:brightness-125 transition-all duration-200 group"
                            >
                                Explore Exit Planning Details
                                <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- Bottom CTA -->
    <section class="bg-tradewise-navy text-white">
        <div class="max-w-7xl mx-auto px-6 py-20 text-center">
            <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4 text-growth-teal">
                Not sure which path is right for you?
            </h2>
            <p class="text-white/60 text-lg mb-8 max-w-xl mx-auto">
                Book a free Strategy Call and we'll help you figure out the best approach for where your
                business is today — no obligation, no pressure.
            </p>
            <a
                href="https://meetings.hubspot.com/tradewise"
                class="inline-block bg-momentum-amber text-white font-semibold px-8 py-4 rounded hover:brightness-110 transition-all duration-200"
            >
                Book a Strategy Call
            </a>
        </div>
    </section>

</MainLayout>
