    {t:'Add a materials escalation clause to new quotes',d:'"Prices valid 14 days. Materials subject to supplier variation."'},
    {t:'Ring your 3 main suppliers — get current price lists',d:'Get it in writing. Ask what\'s happening on 17 April.'},
    {t:'Recalculate your diesel cost per job',d:'Diesel is $3.25+/L nationally. Your travel line is likely undercosted.'},
  ],
  month:[
    {t:'Pre-order materials for all confirmed/signed jobs',d:'Buy at today\'s prices — especially PVC, copper and PE pipes.'},
    {t:'Reprice your 5 oldest open quotes',d:'Anything older than 3 weeks is likely losing you money if accepted.'},
    {t:'Add a visible fuel & freight levy to all quotes',d:'Make it a line item. Clients understand — they\'ve seen the news.'},
    {t:'Move to 30–40% upfront deposits on new jobs',d:'You need cash to pre-buy materials. Protect your cash flow.'},
    {t:'Proactively contact clients — don\'t go quiet',d:'Early communication builds trust. Silence costs you the job.'},
  ],
  quarter:[
    {t:'Move jobs over $30K to cost-plus pricing',d:'Fixed-price lump sum is too risky. Explain this is now industry standard.'},
    {t:'Build a 15–20% materials contingency into your template',d:'This isn\'t padding — it\'s a response to verifiable market conditions.'},
    {t:'Plan for the June cliff — fuel excise cut expires',d:'Any job starting after June needs an escalation clause and fuel buffer.'},
  ]
};
const scTotal=Object.values(scLists).flat().length;
const scChecked={};
function scBuildList(items,id){
  document.getElementById(id).innerHTML=items.map((item,i)=>`
    <div class="sc-check-item" id="${id}-${i}" onclick="scToggleCheck('${id}',${i})">
      <div class="sc-check-box-ui" id="sc-cb-${id}-${i}"><span class="sc-check-tick">✓</span></div>
      <div><div class="sc-check-title">${item.t}</div><div class="sc-check-desc">${item.d}</div></div>
    </div>`).join('');
}
scBuildList(scLists.urgent,'sc-cl-urgent');
scBuildList(scLists.month,'sc-cl-month');
scBuildList(scLists.quarter,'sc-cl-quarter');
function scToggleCheck(id,i){
  const key=id+'-'+i;
  scChecked[key]=!scChecked[key];
  const el=document.getElementById(id+'-'+i);
  scChecked[key]?el.classList.add('done'):el.classList.remove('done');
  const done=Object.values(scChecked).filter(Boolean).length;
  document.getElementById('sc-prog-bar').style.width=(done/scTotal*100)+'%';
  const msgs=['Get cracking!','Good start — keep going!','Making progress.','Over halfway — smashing it!','Nearly there!','Legend! All done. 🎉'];
  const idx=done===scTotal?5:done>scTotal*.8?4:done>scTotal*.6?3:done>scTotal*.4?2:done>0?1:0;
  document.getElementById('sc-prog-label').textContent=done+' of '+scTotal+' actions completed — '+msgs[idx];
}

/* ── HUBSPOT FORM SUBMISSION ──
   Replace PORTAL_ID and FORM_GUID with your HubSpot values.
*/
const SC_PORTAL_ID = '442932388';
const SC_FORM_GUID = 'd32d9b5d-7659-4272-a745-4e93e7fc841b';

function scSubmitForm(){
  const fname   =document.getElementById('sc-fname').value.trim();
  const lname   =document.getElementById('sc-lname').value.trim();
  const email   =document.getElementById('sc-email').value.trim();
  const phone   =document.getElementById('sc-phone').value.trim();
  const biz     =document.getElementById('sc-biz').value.trim();
  const trade   =document.getElementById('sc-trade').value;
  const consent =document.getElementById('sc-consent').checked;
  const errEl   =document.getElementById('sc-form-error');

  if(!fname||!lname||!email||!phone||!biz||!trade||!consent){
    errEl.style.display='block';
    errEl.textContent='Please fill in all required fields and tick the consent box.';
    return;
  }
  if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)){
    errEl.style.display='block';
    errEl.textContent='Please enter a valid email address.';
    return;
  }
  errEl.style.display='none';
  const btn=document.getElementById('sc-submit-btn');
  btn.disabled=true;
  document.getElementById('sc-submit-label').textContent='Submitting...';

  const endpoint=`https://api.hsforms.com/submissions/v3/integration/submit/${SC_PORTAL_ID}/${SC_FORM_GUID}`;
  const payload={
    fields:[
      {objectTypeId:'0-1',name:'firstname',    value:fname},
      {objectTypeId:'0-1',name:'lastname',     value:lname},
      {objectTypeId:'0-1',name:'email',        value:email},
      {objectTypeId:'0-1',name:'phone',        value:phone},
      {objectTypeId:'0-1',name:'company',      value:biz},
      {objectTypeId:'0-1',name:'trade_type',   value:trade},
      {objectTypeId:'0-1',name:'lead_source',  value:'Supply Chain Crisis Article — PDF Download'},
    ],
    context:{pageUri:window.location.href,pageName:'Supply Chain Crisis Action Kit 2026'},
    legalConsentOptions:{
      consent:{
        consentToProcess:true,
        text:'I agree to receive content and resources from Tradewise Group.',
        communications:[{value:true,subscriptionTypeId:999,text:'Marketing emails'}]
      }
    }
  };

  fetch(endpoint,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)})
    .then(()=>scShowSuccess())
    .catch(()=>scShowSuccess());
}

function scShowSuccess(){
  document.getElementById('sc-state-form').classList.remove('active');
  document.getElementById('sc-state-success').classList.add('active');
  document.getElementById('sc-pdf-gate').scrollIntoView({behavior:'smooth',block:'start'});
}

/* ── SCROLL REVEAL ── */
const scObs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');scObs.unobserve(e.target);}});
},{threshold:.07});
document.querySelectorAll('.sc-reveal').forEach(el=>scObs.observe(el));
</script>

