<script is:inline>
/* ── CALCULATOR ── */
function scCalc(){
  const jv=parseFloat(document.getElementById('sc-jv').value)||0;
  const jm=parseFloat(document.getElementById('sc-jm').value)||0;
  const mp=parseFloat(document.getElementById('sc-mp').value)||0;
  const fj=parseFloat(document.getElementById('sc-fj').value)||0;
  const mi=parseFloat(document.getElementById('sc-mi').value)||0;
  const fi=parseFloat(document.getElementById('sc-fi').value)||0;
  const matHit=jv*(mp/100)*(mi/100);
  const fuelHit=fj*(fi/100);
  const hpj=matHit+fuelHit;
  const hpm=hpj*jm;
  const ann=hpm*12;
  const pct=jv>0?(hpj/jv*100):0;
  const col=pct>15?'sc-rv-r':pct>8?'sc-rv-a':'sc-rv-b';
  document.getElementById('sc-results-grid').innerHTML=`
    <div class="sc-result-card"><div class="sc-result-val ${col}">$${Math.round(hpj).toLocaleString('en-AU')}</div><div class="sc-result-label">Extra cost per job</div></div>
    <div class="sc-result-card"><div class="sc-result-val ${col}">$${Math.round(hpm).toLocaleString('en-AU')}</div><div class="sc-result-label">Extra per month</div></div>
    <div class="sc-result-card"><div class="sc-result-val sc-rv-a">$${Math.round(ann).toLocaleString('en-AU')}</div><div class="sc-result-label">Annual hit if costs hold</div></div>
    <div class="sc-result-card"><div class="sc-result-val ${col}">${pct.toFixed(1)}%</div><div class="sc-result-label">Of revenue gone</div></div>`;
  const msg=pct>20?`<strong>🔴 Business survival alert.</strong> At ${pct.toFixed(1)}% of your revenue, this is a real threat. Reprice this week, add surcharges, and have a direct conversation with your clients.`
    :pct>10?`<strong>🟠 Significant pressure.</strong> A ${pct.toFixed(1)}% margin hit needs urgent attention. Shorten your quote validity and add a fuel levy line item now.`
    :pct>4?`<strong>🟡 Manageable but don't ignore it.</strong> At ${pct.toFixed(1)}%, you're exposed but not in crisis yet. Update your quoting template and pre-order materials on confirmed jobs.`
    :`<strong>✅ Lower risk — stay vigilant.</strong> Your exposure looks relatively contained. Build a 10–15% materials contingency into new quotes as a buffer.`;
  document.getElementById('sc-result-narrative').innerHTML=msg;
}
scCalc();

