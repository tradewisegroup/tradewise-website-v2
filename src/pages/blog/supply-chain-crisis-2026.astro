---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout
  title="Supply Chain Crisis — What Tradies Need To Do Right Now | Tradewise Group"
  description="Fuel up 55%. PVC pipes up 36%. Here's exactly what trade business owners in Australia need to do right now to protect their margins."
>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&display=swap" rel="stylesheet" />

<style>
:root {
  --navy:        #1E3A5F;
  --navy-dark:   #141C24;
  --navy-mid:    #1A3254;
  --accent:      #1A7A6E;
  --accent-dark: #14655A;
  --red:         #DC2626;
  --amber:       #D4820A;
  --amber-light: #FEF3C7;
  --green:       #16A34A;
  --green-light: #F0FDF4;
  --grey:        #5A6478;
  --light-grey:  #F4F1EC;
  --border:      #E2E5EC;
  --white:       #FFFFFF;
  --font-display: 'Barlow Condensed', Georgia, serif;
  --font-body:    'Outfit', sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}

/* ALERT BANNER */
.sc-alert-banner{background:var(--red);padding:11px 24px}
.sc-alert-inner{max-width:920px;margin:0 auto;display:flex;align-items:center;gap:12px}
.sc-alert-text{font-size:14px;font-weight:600;color:white;line-height:1.4;font-family:var(--font-body)}
.sc-alert-text span{font-weight:400;opacity:.9}

/* HERO */
.sc-hero{background:var(--navy);padding:56px 24px 64px;position:relative;overflow:hidden}
.sc-hero::before{content:'';position:absolute;top:0;right:0;bottom:0;width:45%;background:repeating-linear-gradient(-45deg,transparent,transparent 14px,rgba(26,122,110,.08) 14px,rgba(26,122,110,.08) 28px);pointer-events:none}
.sc-hero-inner{max-width:920px;margin:0 auto;position:relative}
.sc-hero-kicker{display:inline-flex;align-items:center;gap:8px;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:#7DCCC7;margin-bottom:18px;font-family:var(--font-body)}
.sc-kicker-dot{width:7px;height:7px;background:#F87171;border-radius:50%;animation:sc-blink 1.4s infinite}
@keyframes sc-blink{0%,100%{opacity:1}50%{opacity:.3}}
.sc-hero h1{font-family:var(--font-display);font-weight:900;font-size:clamp(40px,7.5vw,76px);line-height:.97;color:var(--white);text-transform:uppercase;letter-spacing:-.5px;margin-bottom:22px}
.sc-hero h1 em{font-style:normal;color:#F87171;display:block}
.sc-hero-sub{font-size:18px;color:#94A3B8;max-width:600px;line-height:1.55;margin-bottom:32px;font-family:var(--font-body)}
.sc-hero-meta{display:flex;align-items:center;gap:24px;flex-wrap:wrap;border-top:1px solid rgba(255,255,255,.1);padding-top:20px}
.sc-meta-item{font-size:13px;color:#64748B;font-weight:500;font-family:var(--font-body)}
.sc-meta-item strong{color:#CBD5E1}

/* CONTENT */
.sc-cw{max-width:920px;margin:0 auto;padding:0 24px;font-family:var(--font-body)}
@media(max-width:600px){.sc-cw{padding:0 16px}}
.sc-section{padding:52px 0 0}
.sc-section-label{display:inline-flex;align-items:center;gap:10px;font-family:var(--font-display);font-weight:800;font-size:12px;text-transform:uppercase;letter-spacing:.14em;color:var(--accent);margin-bottom:10px}
.sc-section-label::before{content:'';display:block;width:24px;height:3px;background:var(--accent);border-radius:2px}
.sc-section h2{font-family:var(--font-display);font-weight:900;font-size:clamp(28px,4.5vw,44px);text-transform:uppercase;line-height:1.03;color:var(--navy);letter-spacing:-.3px;margin-bottom:24px}
.sc-divider-row{display:flex;align-items:center;gap:14px;margin:52px 0 0}
.sc-divider-row::before,.sc-divider-row::after{content:'';flex:1;height:1px;background:var(--border)}
.sc-divider-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#B0B8C8;white-space:nowrap}

/* CHAIN FLOW */
.sc-chain-flow{display:flex;align-items:stretch;flex-wrap:wrap;gap:8px;margin:28px 0;background:var(--light-grey);border:1px solid var(--border);border-radius:10px;padding:20px 16px}
.sc-chain-node{background:white;border:1.5px solid var(--border);border-radius:8px;padding:14px 12px;text-align:center;flex:1;min-width:110px}
.sc-cn-icon{font-size:22px;margin-bottom:5px}
.sc-cn-label{font-size:12px;font-weight:600;color:var(--navy);line-height:1.3}
.sc-cn-date{font-weight:400;font-size:10px;color:#999}
.sc-chain-node.sc-rn{border-color:#FECACA;background:#FFF5F5}
.sc-chain-node.sc-rn .sc-cn-label{color:var(--red)}
.sc-chain-arrow{color:var(--accent);font-size:18px;font-weight:700;display:flex;align-items:center;flex-shrink:0;padding:0 2px}
@media(max-width:600px){.sc-chain-flow{flex-direction:column}.sc-chain-arrow{transform:rotate(90deg);align-self:center}}

/* FUEL GAUGES */
.sc-fuel-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin:24px 0}
@media(max-width:500px){.sc-fuel-grid{grid-template-columns:1fr}}
.sc-fuel-card{border-radius:10px;padding:20px 16px;text-align:center;border:2px solid}
.sc-fc-red{background:#FFF5F5;border-color:#FECACA}
.sc-fc-amber{background:#FFFBEB;border-color:#FDE68A}
.sc-fuel-title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--grey);margin-bottom:8px}
.sc-fuel-big{font-family:var(--font-display);font-weight:900;font-size:38px;line-height:1;margin-bottom:6px}
.sc-fc-red .sc-fuel-big{color:var(--red)}
.sc-fc-amber .sc-fuel-big{color:#92400E}
.sc-fuel-sub{font-size:12px;color:var(--grey);line-height:1.5}
.sc-fuel-sub strong{display:block;margin-top:2px}

/* MATERIAL HEATMAP */
.sc-heat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:10px;margin:24px 0}
.sc-heat-card{border-radius:8px;padding:14px 16px;display:flex;align-items:center;gap:12px;border:1.5px solid;transition:transform .12s;cursor:default}
.sc-heat-card:hover{transform:translateY(-2px)}
.sc-hc-c{background:#FFF5F5;border-color:#FECACA}
.sc-hc-h{background:#FFFBEB;border-color:#FDE68A}
.sc-hc-m{background:#F0FDFB;border-color:#A7F3D0}
.sc-heat-icon{font-size:22px;width:44px;height:44px;display:flex;align-items:center;justify-content:center;border-radius:8px;flex-shrink:0}
.sc-hc-c .sc-heat-icon{background:#FEE2E2}
.sc-hc-h .sc-heat-icon{background:#FEF3C7}
.sc-hc-m .sc-heat-icon{background:#CCFBF1}
.sc-heat-info{flex:1;min-width:0}
.sc-heat-name{font-size:13px;font-weight:600;color:var(--navy);margin-bottom:1px}
.sc-heat-pct{font-family:var(--font-display);font-weight:900;font-size:22px;line-height:1}
.sc-hc-c .sc-heat-pct{color:var(--red)}
.sc-hc-h .sc-heat-pct{color:#92400E}
.sc-hc-m .sc-heat-pct{color:var(--accent)}
.sc-heat-trade{font-size:11px;color:var(--grey);margin-top:1px}
.sc-heat-badge{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;padding:3px 7px;border-radius:4px;align-self:flex-start;flex-shrink:0}
.sc-hc-c .sc-heat-badge{background:var(--red);color:white}
.sc-hc-h .sc-heat-badge{background:#92400E;color:white}
.sc-hc-m .sc-heat-badge{background:var(--accent);color:white}

/* STAT STRIP */
.sc-stat-strip{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:2px;margin:32px 0;background:var(--border);border:1px solid var(--border);border-radius:10px;overflow:hidden}
.sc-stat-box{background:white;padding:22px 16px;text-align:center}
.sc-stat-num{font-family:var(--font-display);font-weight:900;font-size:38px;line-height:1;margin-bottom:5px}
.sc-sn-r{color:var(--red)}
.sc-sn-a{color:#92400E}
.sc-sn-n{color:var(--navy)}
.sc-stat-label{font-size:12px;color:var(--grey);font-weight:600;text-transform:uppercase;letter-spacing:.04em;line-height:1.4}

/* DOT LIST */
.sc-dot-list{list-style:none;margin:16px 0}
.sc-dot-list li{display:flex;align-items:flex-start;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);font-size:16px;line-height:1.55;color:#374151}
.sc-dot-list li:last-child{border-bottom:none}
.sc-dot-list li::before{content:'';width:8px;height:8px;background:var(--accent);border-radius:50%;flex-shrink:0;margin-top:7px}
.sc-dot-list li strong{color:var(--navy);font-weight:600}

/* CALLOUTS */
.sc-callout{border-left:4px solid var(--accent);background:#F0FDFB;padding:16px 20px;border-radius:0 8px 8px 0;margin:24px 0;font-size:15px;line-height:1.6;color:#374151}
.sc-callout strong{color:var(--navy)}
.sc-callout.sc-danger{border-color:var(--red);background:#FFF5F5}
.sc-callout.sc-success{border-color:var(--green);background:var(--green-light)}
.sc-callout.sc-amber{border-color:var(--amber);background:#FFFBEB}

/* QUOTE ALERT */
.sc-quote-alert{background:var(--red);border-radius:10px;padding:24px 28px;margin:32px 0;display:flex;gap:20px;align-items:flex-start}
.sc-qa-icon{font-size:34px;flex-shrink:0}
.sc-qa-title{font-family:var(--font-display);font-weight:900;font-size:26px;text-transform:uppercase;color:white;letter-spacing:-.2px;margin-bottom:8px}
.sc-qa-body{font-size:15px;line-height:1.6;color:rgba(255,255,255,.9)}
.sc-qa-body strong{font-weight:600;color:white}
@media(max-width:520px){.sc-quote-alert{flex-direction:column;gap:12px}}

/* STEPS */
.sc-steps{margin:24px 0}
.sc-step{display:flex;gap:18px;margin-bottom:4px}
.sc-step-connector{display:flex;flex-direction:column;align-items:center;flex-shrink:0}
.sc-step-num{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-weight:900;font-size:18px;color:white;flex-shrink:0}
.sc-sn-now{background:var(--red)}
.sc-sn-soon{background:var(--amber)}
.sc-sn-later{background:var(--grey)}
.sc-step-line{width:2px;flex:1;background:var(--border);min-height:20px;margin:4px 0}
.sc-step:last-child .sc-step-line{display:none}
.sc-step-body{padding-top:8px;padding-bottom:28px;flex:1}
.sc-step-tag{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;padding:2px 8px;border-radius:3px;margin-bottom:7px;display:inline-block}
.sc-st-now{background:#FEE2E2;color:var(--red)}
.sc-st-soon{background:#FEF3C7;color:#92400E}
.sc-st-later{background:var(--light-grey);color:var(--grey)}
.sc-step-title{font-family:var(--font-display);font-weight:900;font-size:22px;text-transform:uppercase;color:var(--navy);line-height:1.1;margin-bottom:10px}
.sc-step-body ul{list-style:none;padding:0}
.sc-step-body ul li{font-size:15px;color:#374151;padding:5px 0 5px 18px;position:relative;line-height:1.55}
.sc-step-body ul li::before{content:'→';position:absolute;left:0;color:var(--accent);font-weight:600}
.sc-step-body ul li strong{color:var(--navy);font-weight:600}

/* CALCULATOR */
.sc-calc-wrap{background:var(--navy);border-radius:12px;padding:32px;margin:32px 0;color:white}
.sc-calc-title{font-family:var(--font-display);font-weight:900;font-size:30px;text-transform:uppercase;color:white;margin-bottom:4px}
.sc-calc-subtitle{font-size:14px;color:#64748B;margin-bottom:26px}
.sc-calc-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:22px}
@media(max-width:520px){.sc-calc-grid{grid-template-columns:1fr}}
.sc-calc-field label{display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#64748B;margin-bottom:6px}
.sc-calc-field input,.sc-calc-field select{width:100%;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);color:white;padding:10px 14px;border-radius:6px;font-size:16px;font-family:var(--font-body);transition:border-color .15s}
.sc-calc-field input:focus,.sc-calc-field select:focus{outline:none;border-color:var(--accent)}
.sc-calc-field select option{background:var(--navy-dark)}
.sc-slider-wrap{margin:4px 0 22px}
.sc-slider-wrap label{display:flex;justify-content:space-between;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#64748B;margin-bottom:8px}
.sc-slider-wrap label span{font-family:var(--font-display);font-weight:900;font-size:20px;color:#F87171}
input[type=range]{-webkit-appearance:none;width:100%;height:4px;background:rgba(255,255,255,.12);border-radius:2px;outline:none}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:18px;height:18px;background:var(--accent);border-radius:50%;cursor:pointer}
.sc-results-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-top:8px}
.sc-result-card{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:14px 16px}
.sc-result-val{font-family:var(--font-display);font-weight:900;font-size:28px;line-height:1;margin-bottom:4px}
.sc-rv-r{color:#F87171}
.sc-rv-a{color:#FCD34D}
.sc-rv-b{color:#7DCCC7}
.sc-result-label{font-size:11px;color:#64748B;font-weight:700;text-transform:uppercase;letter-spacing:.05em}
.sc-result-narrative{margin-top:18px;padding:16px 18px;background:rgba(26,122,110,.15);border:1px solid rgba(26,122,110,.3);border-radius:8px;font-size:15px;line-height:1.6;color:#CBD5E1}
.sc-result-narrative strong{color:white}

/* CHECKLIST */
.sc-check-group{margin-bottom:28px}
.sc-check-group-title{font-family:var(--font-display);font-weight:800;font-size:17px;text-transform:uppercase;letter-spacing:.04em;padding:10px 16px;border-radius:6px;margin-bottom:4px;display:flex;align-items:center;gap:8px}
.sc-cgt-red{background:#FEE2E2;color:var(--red)}
.sc-cgt-amber{background:#FEF3C7;color:#92400E}
.sc-cgt-grey{background:var(--light-grey);color:var(--grey)}
.sc-check-item{display:flex;align-items:flex-start;gap:14px;padding:13px 16px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .1s;border-radius:6px}
.sc-check-item:hover{background:var(--light-grey)}
.sc-check-item.done{opacity:.5}
.sc-check-box-ui{width:22px;height:22px;border:2px solid var(--border);border-radius:5px;display:flex;align-items:center;justify-content:center;margin-top:1px;transition:all .15s;background:white;flex-shrink:0}
.sc-check-item.done .sc-check-box-ui{background:var(--green);border-color:var(--green)}
.sc-check-tick{display:none;color:white;font-size:13px;font-weight:700}
.sc-check-item.done .sc-check-tick{display:block}
.sc-check-title{font-size:15px;font-weight:600;color:var(--navy);line-height:1.3}
.sc-check-desc{font-size:13px;color:var(--grey);margin-top:3px;line-height:1.4}
.sc-check-item.done .sc-check-title{text-decoration:line-through}
.sc-progress-track{background:var(--border);border-radius:4px;height:6px;margin-bottom:8px;overflow:hidden}
.sc-progress-bar-inner{height:100%;background:var(--green);border-radius:4px;transition:width .3s}
.sc-progress-label{font-size:13px;color:var(--grey);font-weight:500;margin-bottom:24px}

/* PDF GATE */
.sc-pdf-gate{background:var(--navy);border-radius:12px;padding:40px 36px;margin:48px 0;position:relative;overflow:hidden}
.sc-pdf-gate::before{content:'';position:absolute;top:-60px;right:-60px;width:240px;height:240px;background:rgba(26,122,110,.08);border-radius:50%;pointer-events:none}
.sc-pdf-header{display:flex;align-items:flex-start;gap:20px;margin-bottom:24px;flex-wrap:wrap}
.sc-pdf-icon-box{width:60px;height:60px;background:rgba(255,255,255,.08);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0}
.sc-pdf-eyebrow{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#7DCCC7;margin-bottom:6px}
.sc-pdf-title{font-family:var(--font-display);font-weight:900;font-size:28px;text-transform:uppercase;color:white;line-height:1.05;margin-bottom:6px}
.sc-pdf-sub{font-size:15px;color:#94A3B8;line-height:1.5}
.sc-pdf-chips{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:28px}
.sc-pdf-chip{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:6px;padding:6px 12px;font-size:13px;color:#CBD5E1;font-weight:500}
.sc-pdf-chip::before{content:'✓  ';color:#4ADE80}

/* FORM */
.sc-form-state{display:none}
.sc-form-state.active{display:block}
.sc-form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
@media(max-width:520px){.sc-form-row{grid-template-columns:1fr}}
.sc-form-field{display:flex;flex-direction:column;gap:5px}
.sc-form-field label{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#64748B}
.sc-form-field input,.sc-form-field select{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.13);color:white;padding:11px 14px;border-radius:7px;font-size:15px;font-family:var(--font-body);transition:border-color .15s,background .15s;width:100%}
.sc-form-field input::placeholder{color:#475569}
.sc-form-field input:focus,.sc-form-field select:focus{outline:none;border-color:var(--accent);background:rgba(255,255,255,.1)}
.sc-form-field select option{background:#1E3A5F}
.sc-form-consent{display:flex;align-items:flex-start;gap:10px;margin:16px 0 20px}
.sc-form-consent input[type=checkbox]{margin-top:3px;flex-shrink:0;accent-color:var(--accent);width:16px;height:16px}
.sc-form-consent label{font-size:13px;color:#64748B;line-height:1.5}
.sc-form-consent label a{color:#7DCCC7}
.sc-form-submit{width:100%;background:var(--accent);color:white;border:none;padding:14px 24px;border-radius:8px;font-size:16px;font-weight:700;font-family:var(--font-body);cursor:pointer;transition:background .15s;display:flex;align-items:center;justify-content:center;gap:10px}
.sc-form-submit:hover{background:var(--accent-dark)}
.sc-form-submit:disabled{opacity:.6;cursor:not-allowed}
.sc-form-error{background:rgba(220,38,38,.15);border:1px solid rgba(220,38,38,.3);border-radius:6px;padding:10px 14px;font-size:13px;color:#FCA5A5;margin-bottom:14px;display:none}

/* SUCCESS */
.sc-success-state{text-align:center;padding:16px 0}
.sc-success-icon{font-size:56px;margin-bottom:16px}
.sc-success-title{font-family:var(--font-display);font-weight:900;font-size:32px;text-transform:uppercase;color:white;margin-bottom:10px}
.sc-success-body{font-size:15px;color:#94A3B8;line-height:1.6;margin-bottom:28px}
.sc-dl-btn{display:inline-flex;align-items:center;gap:10px;background:#22C55E;color:white;padding:14px 28px;border-radius:8px;font-size:16px;font-weight:700;text-decoration:none;transition:background .15s;margin-bottom:12px}
.sc-dl-btn:hover{background:#16A34A}
.sc-strat-btn{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.18);color:#CBD5E1;padding:12px 24px;border-radius:8px;font-size:15px;font-weight:600;text-decoration:none;transition:background .15s;margin-left:10px}
.sc-strat-btn:hover{background:rgba(255,255,255,.14)}
@media(max-width:520px){.sc-strat-btn{margin-left:0;margin-top:10px}}

/* REVEAL */
.sc-reveal{opacity:0;transform:translateY(18px);transition:opacity .4s,transform .4s}
.sc-reveal.visible{opacity:1;transform:none}

@media(max-width:600px){
  .sc-stat-strip{grid-template-columns:1fr 1fr}
  .sc-heat-grid{grid-template-columns:1fr}
  .sc-fuel-grid{grid-template-columns:1fr}
}
</style>

<!-- ALERT BANNER -->
<div class="sc-alert-banner">
  <div class="sc-alert-inner">
    <div class="sc-alert-text">⚠️ PVC pipes up 36% from 17 April. Diesel at $3.25/L nationally. <span>Scroll down for your action plan.</span></div>
  </div>
</div>

<!-- HERO -->
<div class="sc-hero">
  <div class="sc-hero-inner">
    <div class="sc-hero-kicker"><span class="sc-kicker-dot"></span>Supply Chain Crisis — Australia Wide</div>
    <h1>Your costs<em>just went up.</em>Here's the fix.</h1>
    <p class="sc-hero-sub">The Strait of Hormuz is closed. Fuel is scarce. Material prices are skyrocketing. Here's exactly what every trade business owner in Australia needs to do right now to stay profitable.</p>
    <div class="sc-hero-meta">
      <div class="sc-meta-item">Published <strong>7 April 2026</strong></div>
      <div class="sc-meta-item">By <strong>Tradewise Group</strong></div>
      <div class="sc-meta-item">⏱ <strong>4 min read</strong></div>
      <div class="sc-meta-item">📍 <strong>Australia-wide</strong></div>
    </div>
  </div>
</div>

<div class="sc-cw">

