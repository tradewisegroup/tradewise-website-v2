---
import MainLayout from '../layouts/MainLayout.astro';

const lastUpdated = '11 March 2026';
const companyName = 'TradeWise Group Pty Ltd';
const abn = 'ABN [INSERT ABN]';
const email = 'kate@tradewisegroup.au';
const phone = '1300 TRADEWISE';
---

<MainLayout
    title="Disclaimer | Tradewise Group"
    description="Important disclaimers regarding the information, tools, and services provided by Tradewise Group."
>

    <!-- Header -->
    <section class="bg-tradewise-navy text-white py-16 md:py-20">
        <div class="max-w-7xl mx-auto px-6">
            <div class="max-w-3xl">
                <p class="text-momentum-amber text-sm font-semibold tracking-widest uppercase mb-4">Legal</p>
                <h1 class="font-heading text-4xl md:text-5xl font-bold mb-4 text-growth-teal">Disclaimer</h1>
                <p class="text-white/60 text-sm">Last updated: {lastUpdated}</p>
            </div>
        </div>
    </section>

    <!-- Content -->
    <section class="bg-white">
        <div class="max-w-7xl mx-auto px-6 py-16 md:py-24">
            <div class="grid grid-cols-1 lg:grid-cols-4 gap-12">

                <!-- Sidebar TOC -->
                <aside class="lg:col-span-1">
                    <div class="sticky top-8">
                        <p class="text-xs font-semibold tracking-widest uppercase text-forge-black/40 mb-4">Contents</p>
                        <nav class="flex flex-col gap-2">
                            <a href="#general" class="text-sm text-forge-black/60 hover:text-growth-teal transition-colors duration-150">1. General Disclaimer</a>
                            <a href="#no-financial-advice" class="text-sm text-forge-black/60 hover:text-growth-teal transition-colors duration-150">2. Not Financial Advice</a>
                            <a href="#valuation-tool" class="text-sm text-forge-black/60 hover:text-growth-teal transition-colors duration-150">3. Valuation Scorecard</a>
                            <a href="#no-legal-advice" class="text-sm text-forge-black/60 hover:text-growth-teal transition-colors duration-150">4. Not Legal Advice</a>
                            <a href="#accuracy" class="text-sm text-forge-black/60 hover:text-growth-teal transition-colors duration-150">5. Accuracy of Information</a>
                            <a href="#past-results" class="text-sm text-forge-black/60 hover:text-growth-teal transition-colors duration-150">6. Past Results</a>
                            <a href="#external-links" class="text-sm text-forge-black/60 hover:text-growth-teal transition-colors duration-150">7. External Links</a>
                            <a href="#limitation" class="text-sm text-forge-black/60 hover:text-growth-teal transition-colors duration-150">8. Limitation of Liability</a>
                            <a href="#acl" class="text-sm text-forge-black/60 hover:text-growth-teal transition-colors duration-150">9. Australian Consumer Law</a>
                            <a href="#contact" class="text-sm text-forge-black/60 hover:text-growth-teal transition-colors duration-150">10. Contact Us</a>
                        </nav>
                    </div>
                </aside>

                <!-- Main content -->
                <div class="lg:col-span-3 prose-content">

                    <div class="info-box mb-10">
                        <p>
                            This Disclaimer applies to the Tradewise Group website at <strong>tradewisegroup.au</strong>
                            and all content, tools, and materials published on it. Please read this Disclaimer carefully.
                            By using this Site, you acknowledge and accept the limitations described below.
                        </p>
                    </div>

                    <!-- 1. General -->
                    <section id="general">
                        <h2>1. General Disclaimer</h2>
                        <p>
                            The information published on this website by {companyName} ({abn}) is provided in good faith
                            for general informational purposes only. It is not intended to be comprehensive, and it does not
                            take into account your individual circumstances, business situation, financial position, or
                            objectives.
                        </p>
                        <p>
                            Nothing on this Site constitutes a representation, warranty, or guarantee — express or implied —
                            as to the accuracy, completeness, currentness, reliability, or suitability of any information
                            for any particular purpose.
                        </p>
                        <p>
                            You should not act or refrain from acting on the basis of any information contained on this Site
                            without first obtaining independent professional advice that is specific to your circumstances.
                        </p>
                    </section>

                    <!-- 2. Not Financial Advice -->
                    <section id="no-financial-advice">
                        <h2>2. Not Financial Advice</h2>
                        <p>
                            {companyName} does not hold an Australian Financial Services Licence (AFSL) and does not
                            provide financial product advice as defined under the <em>Corporations Act 2001</em> (Cth).
                        </p>
                        <p>
                            Nothing on this website should be interpreted as:
                        </p>
                        <ul>
                            <li>Financial product advice or a recommendation to acquire or dispose of any financial product</li>
                            <li>Investment advice or a securities recommendation</li>
                            <li>Tax advice or guidance on your tax obligations</li>
                            <li>Superannuation advice</li>
                            <li>Accounting advice specific to your business</li>
                        </ul>
                        <p>
                            Any financial information on this Site is general in nature. Before making any financial decision,
                            you should consider seeking advice from a licensed financial adviser, registered tax agent, or
                            qualified accountant who can assess your specific situation.
                        </p>
                    </section>

                    <!-- 3. Valuation Scorecard -->
                    <section id="valuation-tool">
                        <h2>3. Business Valuation Scorecard</h2>
                        <p>
                            The Business Valuation Scorecard available on this Site is an indicative self-assessment tool.
                            It generates an estimated valuation range based solely on the information you input and a
                            simplified scoring methodology. It is not a formal business valuation.
                        </p>

                        <div class="warning-box">
                            <strong>Important limitations of the Scorecard:</strong>
                            <ul style="margin-top: 0.5rem;">
                                <li>Results are based on data you self-report — we do not verify financial figures</li>
                                <li>The methodology uses generalised industry multiples and does not account for your specific industry, geography, buyer market, or deal structure</li>
                                <li>Actual business valuations require professional assessment by a qualified business valuer or broker, and are affected by many factors the Scorecard cannot capture</li>
                                <li>Market conditions, buyer appetite, due diligence findings, and negotiation outcomes all influence the final sale price of a business</li>
                                <li>The Scorecard output should not be used as a basis for any financial, legal, or commercial decision</li>
                            </ul>
                        </div>

                        <p>
                            The Scorecard is provided as a free, educational tool to help business owners begin thinking about
                            business value drivers. For a formal valuation, we recommend engaging a qualified business broker
                            or registered business valuer.
                        </p>
                        <p>
                            Tradewise Group is not a licensed business broker or registered valuer. Any valuation guidance we
                            provide as part of our advisory services is directional and informational only, not a formal
                            valuation report.
                        </p>
                    </section>

                    <!-- 4. Not Legal Advice -->
                    <section id="no-legal-advice">
                        <h2>4. Not Legal Advice</h2>
                        <p>
                            Nothing on this Site constitutes legal advice. Any references to legislation, regulations,
                            compliance obligations, or legal frameworks are for general informational purposes only.
                        </p>
                        <p>
                            Legal requirements vary depending on your business structure, state or territory, industry,
                            employee arrangements, and other factors. You should seek independent legal advice from a
                            qualified Australian lawyer before making decisions based on any legal information on this Site.
                        </p>
                        <p>
                            In particular, references to equity partnerships, staged buyouts, and business sale structures
                            on this Site are high-level descriptions of common transaction types. The legal structure,
                            documentation, and obligations applicable to any specific transaction will depend on your
                            circumstances and require independent legal review.
                        </p>
                    </section>

                    <!-- 5. Accuracy -->
                    <section id="accuracy">
                        <h2>5. Accuracy and Currency of Information</h2>
                        <p>
                            While we take reasonable steps to ensure that the information on this Site is accurate and
                            up to date, we make no representation or warranty — express or implied — that it is complete,
                            accurate, or current at the time of access.
                        </p>
                        <p>
                            Information on this Site may include forward-looking statements, projections, or general
                            commentary about market trends and business conditions. These statements involve known and
                            unknown risks and uncertainties. Actual outcomes may differ materially from those described.
                        </p>
                        <p>
                            Legislative, regulatory, and industry requirements change over time. Legislation cited on this
                            Site (including the <em>Privacy Act 1988</em>, <em>Corporations Act 2001</em>,
                            <em>Competition and Consumer Act 2010</em>, and others) may have been amended since publication.
                            Always verify current legislative requirements with a qualified professional.
                        </p>
                    </section>

                    <!-- 6. Past Results -->
                    <section id="past-results">
                        <h2>6. Past Results Are Not Indicative of Future Outcomes</h2>
                        <p>
                            Any case studies, testimonials, examples, or results mentioned on this Site represent
                            specific engagements under particular circumstances. They are provided for illustrative
                            purposes only.
                        </p>
                        <p>
                            Past results achieved for other clients do not guarantee similar results for your business.
                            Business performance, growth, and outcomes depend on many variables including your specific
                            industry, market conditions, team, financial position, and the effort you and your team invest.
                        </p>
                        <p>
                            We present examples and estimates in good faith to illustrate potential value. They should not
                            be interpreted as promises or guarantees of specific outcomes.
                        </p>
                    </section>

                    <!-- 7. External Links -->
                    <section id="external-links">
                        <h2>7. External Links</h2>
                        <p>
                            This Site may contain links to external websites and third-party platforms (including HubSpot
                            booking pages, government websites, and industry bodies). These links are provided for
                            convenience only.
                        </p>
                        <p>
                            {companyName} does not endorse, control, or accept responsibility for the accuracy, completeness,
                            reliability, or legality of any content on linked external sites. Linking to a third-party site
                            does not imply any affiliation, sponsorship, or endorsement by Tradewise Group.
                        </p>
                        <p>
                            You access external links at your own risk. We recommend reviewing the terms of use and privacy
                            policy of any external site before providing personal or business information.
                        </p>
                    </section>

                    <!-- 8. Limitation of Liability -->
                    <section id="limitation">
                        <h2>8. Limitation of Liability</h2>
                        <p>
                            To the fullest extent permitted by law, {companyName} and its directors, officers, employees,
                            contractors, agents, and affiliates exclude all liability for:
                        </p>
                        <ul>
                            <li>Any loss or damage (direct, indirect, consequential, or otherwise) arising from reliance on information on this Site</li>
                            <li>Decisions made based on Scorecard outputs or general content on this Site</li>
                            <li>Errors, omissions, or inaccuracies in any content on this Site</li>
                            <li>Interruptions or unavailability of the Site</li>
                            <li>Any loss of data, revenue, or business opportunity arising from use of or inability to use the Site</li>
                            <li>Content published on third-party sites linked from this Site</li>
                        </ul>
                        <p>
                            Where liability cannot be excluded under applicable Australian law, our liability is limited
                            to the minimum extent permitted by that law.
                        </p>
                    </section>

                    <!-- 9. ACL -->
                    <section id="acl">
                        <h2>9. Australian Consumer Law</h2>
                        <p>
                            Our services and this website are subject to the <em>Australian Consumer Law</em> (ACL),
                            being Schedule 2 to the <em>Competition and Consumer Act 2010</em> (Cth). Nothing in this
                            Disclaimer is intended to exclude, limit, or modify any right or remedy you have under the
                            ACL or other applicable consumer protection legislation that cannot lawfully be excluded.
                        </p>
                        <p>
                            The ACCC (Australian Competition and Consumer Commission) administers the ACL and provides
                            consumer guidance at <a href="https://www.accc.gov.au" class="text-growth-teal hover:underline" target="_blank" rel="noopener noreferrer">accc.gov.au</a>.
                            If you believe we have engaged in misleading or deceptive conduct or made false representations,
                            you are entitled to raise a complaint with the ACCC or seek your rights under the ACL.
                        </p>
                    </section>

                    <!-- 10. Contact -->
                    <section id="contact">
                        <h2>10. Questions & Concerns</h2>
                        <p>
                            If you have any questions about this Disclaimer or concerns about any information on our Site,
                            please contact us:
                        </p>
                        <ul>
                            <li><strong>Email:</strong> <a href={`mailto:${email}`} class="text-growth-teal hover:underline">{email}</a></li>
                            <li><strong>Phone:</strong> {phone}</li>
                        </ul>
                        <p>
                            For privacy-related concerns, see our <a href="/privacy-policy" class="text-growth-teal hover:underline">Privacy Policy</a>.
                            For the terms governing your use of this Site, see our <a href="/terms-of-use" class="text-growth-teal hover:underline">Terms of Use</a>.
                        </p>
                    </section>

                </div>
            </div>
        </div>
    </section>

</MainLayout>

<style>
    .prose-content section {
        margin-bottom: 3rem;
    }

    .prose-content h2 {
        font-family: Georgia, serif;
        font-size: 1.375rem;
        font-weight: 700;
        color: #141C24;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #1A7A6E;
    }

    .prose-content p {
        color: rgba(20, 28, 36, 0.70);
        line-height: 1.75;
        font-size: 0.9375rem;
        margin-bottom: 1rem;
    }

    .prose-content ul {
        list-style: none;
        padding: 0;
        margin-bottom: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .prose-content ul li {
        display: flex;
        align-items: flex-start;
        gap: 0.625rem;
        color: rgba(20, 28, 36, 0.70);
        font-size: 0.9375rem;
        line-height: 1.6;
    }

    .prose-content ul li::before {
        content: '';
        display: block;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #D4820A;
        flex-shrink: 0;
        margin-top: 0.55rem;
    }

    .info-box {
        background: rgba(26, 122, 110, 0.07);
        border-left: 4px solid #1A7A6E;
        border-radius: 0 0.5rem 0.5rem 0;
        padding: 1rem 1.25rem;
        color: rgba(20, 28, 36, 0.75);
        font-size: 0.9rem;
        line-height: 1.65;
        margin-bottom: 1.25rem;
    }

    .warning-box {
        background: rgba(212, 130, 10, 0.08);
        border-left: 4px solid #D4820A;
        border-radius: 0 0.5rem 0.5rem 0;
        padding: 1rem 1.25rem;
        color: rgba(20, 28, 36, 0.75);
        font-size: 0.9rem;
        line-height: 1.65;
        margin-bottom: 1.25rem;
    }

    .warning-box ul {
        margin: 0;
    }

    .info-box ul li::before,
    .warning-box ul li::before {
        background: #D4820A;
    }
</style>
