---
import MainLayout from '../layouts/MainLayout.astro';

const questions = [
    {
        driver: 'Owner Reliance',
        question: 'How dependent is the day-to-day running of your business on you personally?',
        service: 'Our Systems & Processes service is designed to reduce owner dependency and build a self-managing business.',
        options: [
            "I'm involved in everything — if I'm not there, things stop.",
            "I have staff who handle tasks, but key decisions still come back to me.",
            "I have a management layer that runs operations independently — I work on the business, not in it.",
        ],
    },
    {
        driver: 'Recurring Revenue',
        question: 'How predictable and recurring is your revenue?',
        service: 'Our Revenue Strategy service helps you build contracted, predictable income streams that buyers pay a premium for.',
        options: [
            "Almost all work is one-off or reactive — we win it job by job.",
            "We have some repeat customers and service agreements, but nothing formally contracted.",
            "The majority of our revenue comes from contracts, retainers, or highly predictable repeat customers.",
        ],
    },
    {
        driver: 'Systems & Processes',
        question: 'How well documented and systematised are your day-to-day operations?',
        service: 'Our Operational Systems service will document and systematise your key workflows so the business runs without you.',
        options: [
            "Most things live in my head — there are no formal procedures.",
            "Some processes are written down but aren't consistently followed.",
            "We have SOPs for all key functions and staff follow them independently.",
        ],
    },
    {
        driver: 'Team & Leadership',
        question: 'How capable and independent is your leadership team?',
        service: 'Our Team & Leadership service helps you build a management structure that operates confidently without you.',
        options: [
            "It's just me, or my staff need constant guidance to get things done.",
            "I have some trusted senior staff, but no formal management structure.",
            "I have a capable management team that handles hiring, performance, and operations.",
        ],
    },
    {
        driver: 'Financial Clarity',
        question: 'How clear and up-to-date is your financial visibility?',
        service: 'Our Financial Clarity service delivers real-time P&L, cash flow forecasts, and job-level profitability tracking.',
        options: [
            "I find out how profitable I am at tax time — cash flow is reactive.",
            "I check the numbers occasionally but don't have a regular reporting rhythm.",
            "I have monthly P&L, cash flow forecasts, and job-level profitability tracked in real time.",
        ],
    },
    {
        driver: 'Customer Concentration',
        question: 'How spread is your revenue across your customer base?',
        service: 'Our Growth & Marketing service diversifies your client base and reduces the concentration risk that scares buyers.',
        options: [
            "One or two clients make up more than 50% of our revenue.",
            "I have a handful of good clients but still rely heavily on a few.",
            "No single client represents more than 15–20% of total revenue.",
        ],
    },
    {
        driver: 'Growth & Scalability',
        question: 'How well-positioned is your business to grow without you personally doing more work?',
        service: 'Our Scale & Exit service prepares your business model for sustainable, owner-independent growth.',
        options: [
            "Growth means I personally work more hours — I'm the bottleneck.",
            "I could grow, but I'd need to hire and train significantly before stepping back.",
            "Our systems, team, and model are ready to scale — we could take on more work today.",
        ],
    },
    {
        driver: 'Brand & Market Position',
        question: "How strong is your business's reputation and brand in your market?",
        service: 'Our Brand & Marketing service strengthens your market position and builds a consistent inbound lead pipeline.',
        options: [
            "Most work comes through word of mouth from my personal network.",
            "We have a decent reputation, but our brand and marketing are inconsistent.",
            "We have a strong brand, consistent marketing, and are seen as the go-to provider in our area.",
        ],
    },
];

const situationOptions = [
    "I'm doing everything myself and just want things to run smoother.",
    "I've got a good team and demand, but the back end is holding us back.",
    "I'm thinking about selling in the next few years and want to maximise what I walk away with.",
    "I love the trade but the business side is burning me out.",
];
---

<MainLayout
    title="Business Valuation Scorecard | Tradewise Group"
    description="Find out what your trade business is really worth. Get a free estimated valuation range in under 5 minutes using the same methodology used by trade business brokers and buyers."
>

    <!-- ===================== HERO ===================== -->
    <section class="bg-tradewise-navy text-white py-20 md:py-28">
        <div class="max-w-3xl mx-auto px-6 text-center">
            <p class="text-momentum-amber text-sm font-semibold tracking-widest uppercase mb-6">
                Free Valuation Tool
            </p>
            <h1 class="font-heading text-4xl md:text-5xl font-bold mb-6 leading-tight text-growth-teal">
                Find Out What Your Trade Business is
                <span style="color:#D4820A;font-style:italic"> Really</span> Worth.
            </h1>
            <p class="text-white/70 text-lg leading-relaxed max-w-2xl mx-auto">
                Answer a few questions about your finances and operations. We'll calculate your
                estimated valuation range using the same methodology used by trade business
                brokers and buyers — in under 5 minutes.
            </p>
        </div>
    </section>

    <!-- ===================== FORM AREA ===================== -->
    <section class="bg-concrete py-16 md:py-24 min-h-screen">
        <div class="max-w-2xl mx-auto px-6">

            <!-- Step Indicator -->
            <div class="mb-10" id="step-indicator">
                <div class="flex items-center">
                    {['Financial Details', 'Assessment', 'Your Details', 'Results'].map((label, i) => (
                        <div class={`flex items-center ${i < 3 ? 'flex-1' : ''}`}>
                            <div class="flex flex-col items-center">
                                <div
                                    id={`step-dot-${i + 1}`}
                                    class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold transition-all duration-300"
                                    style={i === 0 ? 'background:#1E3A5F;color:white' : 'background:#E5E0D8;color:#9CA3AF'}
                                >
                                    {i + 1}
                                </div>
                                <span
                                    id={`step-label-${i + 1}`}
                                    class="text-xs font-medium mt-1.5 hidden sm:block whitespace-nowrap"
                                    style={i === 0 ? 'color:#1E3A5F' : 'color:#9CA3AF'}
                                >
                                    {label}
                                </span>
                            </div>
                            {i < 3 && (
                                <div
                                    id={`step-line-${i + 1}`}
                                    class="flex-1 h-px mx-3 -mt-5 sm:-mt-5 transition-all duration-300"
                                    style="background:#E5E0D8"
                                ></div>
                            )}
                        </div>
                    ))}
                </div>
            </div>

            <!-- =========== STEP 1: Financial Input =========== -->
            <div id="step-1">
                <div class="bg-white rounded-xl p-8 shadow-sm mb-6">
                    <p class="text-momentum-amber text-xs font-semibold tracking-widest uppercase mb-3">Step 1 of 4</p>
                    <h2 class="font-heading text-2xl font-bold text-forge-black mb-2">Your Financial Overview</h2>
                    <p class="text-forge-black/50 text-sm mb-8 leading-relaxed">
                        Use your most recent full financial year. These three numbers form the
                        foundation of your valuation. Your data is never stored or shared.
                    </p>

                    <div class="flex flex-col gap-7">
                        <!-- Revenue -->
                        <div>
                            <label for="f-revenue" class="block text-sm font-semibold text-forge-black mb-1">
                                Annual Revenue <span class="text-red-400">*</span>
                            </label>
                            <p class="text-forge-black/40 text-xs mb-2">Total business income before any expenses.</p>
                            <div class="relative">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-forge-black/40 text-sm font-semibold select-none">$</span>
                                <input
                                    type="number" id="f-revenue" min="0" placeholder="e.g. 2500000"
                                    class="w-full border border-forge-black/20 rounded-lg pl-8 pr-4 py-3 text-sm text-forge-black focus:outline-none focus:border-tradewise-navy transition-colors duration-150"
                                />
                            </div>
                            <p id="err-revenue" class="text-red-500 text-xs mt-1.5 hidden">Please enter your annual revenue.</p>
                        </div>

                        <!-- Net Profit -->
                        <div>
                            <label for="f-profit" class="block text-sm font-semibold text-forge-black mb-1">
                                Annual Net Profit <span class="text-forge-black/40 font-normal">(before tax & your wage)</span>
                                <span class="text-red-400">*</span>
                            </label>
                            <p class="text-forge-black/40 text-xs mb-2">
                                Your business profit before paying yourself or paying tax. Often called EBIT or adjusted NPBT.
                            </p>
                            <div class="relative">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-forge-black/40 text-sm font-semibold select-none">$</span>
                                <input
                                    type="number" id="f-profit" min="0" placeholder="e.g. 450000"
                                    class="w-full border border-forge-black/20 rounded-lg pl-8 pr-4 py-3 text-sm text-forge-black focus:outline-none focus:border-tradewise-navy transition-colors duration-150"
                                />
                            </div>
                            <p id="err-profit" class="text-red-500 text-xs mt-1.5 hidden">Please enter your net profit.</p>
                        </div>

                        <!-- Salary -->
                        <div>
                            <label for="f-salary" class="block text-sm font-semibold text-forge-black mb-1">
                                Your Annual Salary & Perks <span class="text-red-400">*</span>
                            </label>
                            <p class="text-forge-black/40 text-xs mb-2">
                                What you pay yourself — wages, drawings, super, vehicle, and any personal expenses run through the business.
                            </p>
                            <div class="relative">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-forge-black/40 text-sm font-semibold select-none">$</span>
                                <input
                                    type="number" id="f-salary" min="0" placeholder="e.g. 120000"
                                    class="w-full border border-forge-black/20 rounded-lg pl-8 pr-4 py-3 text-sm text-forge-black focus:outline-none focus:border-tradewise-navy transition-colors duration-150"
                                />
                            </div>
                            <p id="err-salary" class="text-red-500 text-xs mt-1.5 hidden">Please enter your salary & perks.</p>
                        </div>
                    </div>
                </div>

                <p class="text-forge-black/35 text-xs italic leading-relaxed mb-6">
                    <strong class="not-italic font-semibold">Disclaimer:</strong> This tool provides an indicative estimate only and does not constitute a formal business valuation, financial advice, legal advice, or investment advice. Results are based solely on the information you provide and do not account for market conditions, due diligence findings, buyer appetite, or other factors that influence actual sale outcomes. TradeWise Group Pty Ltd makes no representation or warranty as to the accuracy of these estimates. You should seek independent advice from a qualified business valuer, accountant, and/or legal adviser before making any decisions relating to the sale or transfer of your business.
                </p>

                <div class="flex justify-end">
                    <button
                        id="btn-step1-next"
                        class="bg-tradewise-navy text-white font-semibold text-sm px-8 py-3 rounded-lg hover:brightness-110 transition-all duration-200"
                    >
                        Next: The Assessment →
                    </button>
                </div>
            </div>

            <!-- =========== STEP 2: 8 Questions =========== -->
            <div id="step-2" style="display:none">

                <!-- Question sub-progress -->
                <div class="flex justify-between items-center mb-2">
                    <span class="text-sm text-forge-black/50 font-medium">
                        Question <span id="q-num">1</span> of 8
                    </span>
                    <span class="text-sm text-forge-black/50 font-medium">
                        <span id="q-pct">0</span>% complete
                    </span>
                </div>
                <div class="w-full bg-forge-black/10 rounded-full h-1 mb-8">
                    <div id="q-bar" class="bg-momentum-amber h-1 rounded-full transition-all duration-500" style="width:0%"></div>
                </div>

                {questions.map((q, i) => (
                    <div class="q-card" data-qi={i} style={i === 0 ? '' : 'display:none'}>
                        <div class="bg-white rounded-xl p-8 shadow-sm mb-6">
                            <p class="text-momentum-amber text-xs font-semibold tracking-widest uppercase mb-3">
                                Value Driver {i + 1} of 8 — {q.driver}
                            </p>
                            <h2 class="font-heading text-xl font-bold text-forge-black mb-6">
                                {q.question}
                            </h2>
                            <div class="flex flex-col gap-3">
                                {q.options.map((opt, j) => {
                                    const vals = [2, 6, 12.5];
                                    return (
                                        <label class="flex items-start gap-4 border border-forge-black/10 rounded-lg p-4 cursor-pointer hover:border-tradewise-navy/30 transition-colors duration-150 has-[:checked]:border-tradewise-navy has-[:checked]:bg-tradewise-navy/5">
                                            <input
                                                type="radio"
                                                name={`q${i}`}
                                                value={String(vals[j])}
                                                class="mt-0.5 shrink-0 accent-tradewise-navy"
                                            />
                                            <p class="text-forge-black text-sm font-medium leading-relaxed">{opt}</p>
                                        </label>
                                    );
                                })}
                            </div>
                        </div>

                        <div class="flex justify-between items-center">
                            <button
                                class="q-prev-btn text-sm text-forge-black/50 hover:text-forge-black transition-colors duration-150 px-4 py-2"
                                data-qi={i}
                            >
                                ← Back
                            </button>
                            {i < questions.length - 1 ? (
                                <button
                                    class="q-next-btn bg-tradewise-navy text-white font-semibold text-sm px-6 py-3 rounded-lg hover:brightness-110 transition-all duration-200"
                                    data-qi={i}
                                >
                                    Next →
                                </button>
                            ) : (
                                <button
                                    id="btn-step2-done"
                                    class="bg-tradewise-navy text-white font-semibold text-sm px-6 py-3 rounded-lg hover:brightness-110 transition-all duration-200"
                                    data-qi={i}
                                >
                                    Next: Your Details →
                                </button>
                            )}
                        </div>
                    </div>
                ))}
            </div>

            <!-- =========== STEP 3: Lead Capture =========== -->
            <div id="step-3" style="display:none">
                <div class="bg-white rounded-xl p-8 shadow-sm mb-6">
                    <p class="text-momentum-amber text-xs font-semibold tracking-widest uppercase mb-3">Step 3 of 4</p>
                    <h2 class="font-heading text-2xl font-bold text-forge-black mb-2">
                        Almost there — enter your details to unlock your valuation.
                    </h2>
                    <p class="text-forge-black/50 text-sm mb-8">
                        Your results are calculated and ready. Enter your details below and we'll display your
                        personalised valuation report immediately.
                    </p>

                    <form id="lead-form" novalidate class="flex flex-col gap-5">

                        <!-- First / Last Name -->
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label for="lf-first" class="block text-sm font-semibold text-forge-black mb-1">
                                    First Name <span class="text-red-400">*</span>
                                </label>
                                <input
                                    type="text" id="lf-first" name="firstname" autocomplete="given-name"
                                    class="w-full border border-forge-black/20 rounded-lg px-4 py-3 text-sm text-forge-black focus:outline-none focus:border-tradewise-navy transition-colors duration-150"
                                />
                                <p class="lf-err text-red-500 text-xs mt-1 hidden">Required</p>
                            </div>
                            <div>
                                <label for="lf-last" class="block text-sm font-semibold text-forge-black mb-1">
                                    Last Name <span class="text-red-400">*</span>
                                </label>
                                <input
                                    type="text" id="lf-last" name="lastname" autocomplete="family-name"
                                    class="w-full border border-forge-black/20 rounded-lg px-4 py-3 text-sm text-forge-black focus:outline-none focus:border-tradewise-navy transition-colors duration-150"
                                />
                                <p class="lf-err text-red-500 text-xs mt-1 hidden">Required</p>
                            </div>
                        </div>

                        <!-- Email / Phone -->
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label for="lf-email" class="block text-sm font-semibold text-forge-black mb-1">
                                    Email <span class="text-red-400">*</span>
                                </label>
                                <input
                                    type="email" id="lf-email" name="email" autocomplete="email"
                                    class="w-full border border-forge-black/20 rounded-lg px-4 py-3 text-sm text-forge-black focus:outline-none focus:border-tradewise-navy transition-colors duration-150"
                                />
                                <p class="lf-err text-red-500 text-xs mt-1 hidden">Please enter a valid email</p>
                            </div>
                            <div>
                                <label for="lf-phone" class="block text-sm font-semibold text-forge-black mb-1">
                                    Phone Number <span class="text-red-400">*</span>
                                </label>
                                <input
                                    type="tel" id="lf-phone" name="phone" autocomplete="tel"
                                    class="w-full border border-forge-black/20 rounded-lg px-4 py-3 text-sm text-forge-black focus:outline-none focus:border-tradewise-navy transition-colors duration-150"
                                />
                                <p class="lf-err text-red-500 text-xs mt-1 hidden">Required</p>
                            </div>
                        </div>

                        <!-- Company / Trade Type -->
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label for="lf-company" class="block text-sm font-semibold text-forge-black mb-1">
                                    Company Name <span class="text-red-400">*</span>
                                </label>
                                <input
                                    type="text" id="lf-company" name="company" autocomplete="organization"
                                    class="w-full border border-forge-black/20 rounded-lg px-4 py-3 text-sm text-forge-black focus:outline-none focus:border-tradewise-navy transition-colors duration-150"
                                />
                                <p class="lf-err text-red-500 text-xs mt-1 hidden">Required</p>
                            </div>
                            <div>
                                <label for="lf-trade" class="block text-sm font-semibold text-forge-black mb-1">
                                    Trade Type <span class="text-red-400">*</span>
                                </label>
                                <div class="relative">
                                    <select
                                        id="lf-trade" name="trade_type"
                                        class="w-full border border-forge-black/20 rounded-lg px-4 py-3 text-sm text-forge-black bg-white focus:outline-none focus:border-tradewise-navy transition-colors duration-150 appearance-none pr-10"
                                    >
                                        <option value="">Select trade type...</option>
                                        <option>Plumbing</option>
                                        <option>Electrical</option>
                                        <option>HVAC</option>
                                        <option>Building/Construction</option>
                                        <option>Painting</option>
                                        <option>Roofing</option>
                                        <option>Landscaping</option>
                                        <option>Fire Services</option>
                                        <option>Other</option>
                                    </select>
                                    <span class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-forge-black/40 text-xs">▼</span>
                                </div>
                                <p class="lf-err text-red-500 text-xs mt-1 hidden">Required</p>
                            </div>
                        </div>

                        <!-- Employees / Location -->
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label for="lf-employees" class="block text-sm font-semibold text-forge-black mb-1">
                                    Number of Employees <span class="text-red-400">*</span>
                                </label>
                                <div class="relative">
                                    <select
                                        id="lf-employees" name="num_employees"
                                        class="w-full border border-forge-black/20 rounded-lg px-4 py-3 text-sm text-forge-black bg-white focus:outline-none focus:border-tradewise-navy transition-colors duration-150 appearance-none pr-10"
                                    >
                                        <option value="">Select range...</option>
                                        <option>1-5</option>
                                        <option>6-10</option>
                                        <option>11-20</option>
                                        <option>21-50</option>
                                        <option>50+</option>
                                    </select>
                                    <span class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-forge-black/40 text-xs">▼</span>
                                </div>
                                <p class="lf-err text-red-500 text-xs mt-1 hidden">Required</p>
                            </div>
                            <div>
                                <label for="lf-location" class="block text-sm font-semibold text-forge-black mb-1">
                                    Location / State <span class="text-red-400">*</span>
                                </label>
                                <div class="relative">
                                    <select
                                        id="lf-location" name="state"
                                        class="w-full border border-forge-black/20 rounded-lg px-4 py-3 text-sm text-forge-black bg-white focus:outline-none focus:border-tradewise-navy transition-colors duration-150 appearance-none pr-10"
                                    >
                                        <option value="">Select state...</option>
                                        <option>QLD</option>
                                        <option>NSW</option>
                                        <option>VIC</option>
                                        <option>SA</option>
                                        <option>WA</option>
                                        <option>TAS</option>
                                        <option>NT</option>
                                        <option>ACT</option>
                                        <option>New Zealand</option>
                                        <option>Other</option>
                                    </select>
                                    <span class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-forge-black/40 text-xs">▼</span>
                                </div>
                                <p class="lf-err text-red-500 text-xs mt-1 hidden">Required</p>
                            </div>
                        </div>

                        <!-- Situation radio -->
                        <div>
                            <p class="text-sm font-semibold text-forge-black mb-3">
                                What best describes where you're at right now? <span class="text-red-400">*</span>
                            </p>
                            <div class="flex flex-col gap-2">
                                {situationOptions.map((opt) => (
                                    <label class="flex items-start gap-3 border border-forge-black/10 rounded-lg p-3.5 cursor-pointer hover:border-tradewise-navy/30 transition-colors duration-150 has-[:checked]:border-tradewise-navy has-[:checked]:bg-tradewise-navy/5">
                                        <input
                                            type="radio" name="current_situation" value={opt}
                                            class="mt-0.5 shrink-0 accent-tradewise-navy"
                                        />
                                        <span class="text-sm text-forge-black leading-relaxed">{opt}</span>
                                    </label>
                                ))}
                            </div>
                            <p id="err-situation" class="text-red-500 text-xs mt-1.5 hidden">Please select an option.</p>
                        </div>

                        <p id="err-hubspot" class="text-red-500 text-sm hidden">
                            Something went wrong submitting your details — please try again.
                        </p>

                        <p class="text-forge-black/30 text-xs italic leading-relaxed border-t border-forge-black/8 pt-4">
                            <strong class="not-italic font-semibold">Disclaimer:</strong> This tool provides an indicative estimate only and does not constitute a formal business valuation, financial advice, legal advice, or investment advice. Results are based solely on the information you provide and do not account for market conditions, due diligence findings, buyer appetite, or other factors that influence actual sale outcomes. TradeWise Group Pty Ltd makes no representation or warranty as to the accuracy of these estimates. You should seek independent advice from a qualified business valuer, accountant, and/or legal adviser before making any decisions relating to the sale or transfer of your business.
                        </p>

                        <div class="flex justify-between items-center pt-2">
                            <button
                                type="button" id="btn-step3-back"
                                class="text-sm text-forge-black/50 hover:text-forge-black transition-colors duration-150 px-4 py-2"
                            >
                                ← Back
                            </button>
                            <button
                                type="submit" id="btn-step3-submit"
                                class="bg-momentum-amber text-white font-semibold text-sm px-8 py-3 rounded-lg hover:brightness-110 transition-all duration-200 flex items-center gap-2 disabled:opacity-60 disabled:cursor-not-allowed"
                            >
                                <span id="submit-label">Show My Valuation →</span>
                                <svg id="submit-spinner" class="hidden animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                                </svg>
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- =========== STEP 4: Results =========== -->
            <div id="step-4" style="display:none">

                <!-- Valuation Card -->
                <div class="bg-tradewise-navy text-white rounded-xl p-8 mb-6 text-center">
                    <p class="text-momentum-amber text-xs font-semibold tracking-widest uppercase mb-5">
                        Your Estimated Business Valuation
                    </p>

                    <div class="flex justify-center items-end gap-6 mb-3 flex-wrap">
                        <div>
                            <p class="text-white/40 text-xs uppercase tracking-wider mb-1">Low Estimate</p>
                            <p id="r-val-low" class="font-heading text-4xl md:text-5xl font-bold text-growth-teal"></p>
                        </div>
                        <div class="text-white/25 text-3xl font-heading pb-2">—</div>
                        <div>
