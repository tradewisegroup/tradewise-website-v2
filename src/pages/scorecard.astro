<script is:inline>
// ===================== CONFIG =====================
var HS_PORTAL_ID = '442932388';
var HS_FORM_GUID  = '35c92a91-6509-41b6-83e0-9db9f66c7ba8';

// ===================== STATE =====================
var financials   = { revenue: 0, profit: 0, salary: 0 };
var currentQ     = 0;
var cachedResults = null;

// ===================== ELEMENTS =====================
var step1El  = document.getElementById('step-1');
var step2El  = document.getElementById('step-2');
var step3El  = document.getElementById('step-3');
var step4El  = document.getElementById('step-4');
var qCards   = document.querySelectorAll('.q-card');
var qNumEl   = document.getElementById('q-num');
var qPctEl   = document.getElementById('q-pct');
var qBarEl   = document.getElementById('q-bar');

// ===================== STEP INDICATOR =====================
function setStep(n) {
    [1, 2, 3, 4].forEach(function(i) {
        var dot   = document.getElementById('step-dot-' + i);
        var label = document.getElementById('step-label-' + i);
        if (!dot) return;
        if (i < n) {
            dot.style.background = '#1A7A6E';
            dot.style.color      = 'white';
            dot.textContent      = '✓';
            if (label) label.style.color = '#1A7A6E';
        } else if (i === n) {
            dot.style.background = '#1E3A5F';
            dot.style.color      = 'white';
            dot.textContent      = String(i);
            if (label) label.style.color = '#1E3A5F';
        } else {
            dot.style.background = '#E5E0D8';
            dot.style.color      = '#9CA3AF';
            dot.textContent      = String(i);
            if (label) label.style.color = '#9CA3AF';
        }
    });
    [1, 2, 3].forEach(function(i) {
        var line = document.getElementById('step-line-' + i);
        if (line) line.style.background = n > i ? '#1A7A6E' : '#E5E0D8';
    });
}

// ===================== NAVIGATION =====================
function goToStep(n) {
    step1El.style.display = n === 1 ? 'block' : 'none';
    step2El.style.display = n === 2 ? 'block' : 'none';
    step3El.style.display = n === 3 ? 'block' : 'none';
    step4El.style.display = n === 4 ? 'block' : 'none';
    setStep(n);
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

function showQuestion(qi) {
    currentQ = qi;
    qCards.forEach(function(card, i) {
        card.style.display = i === qi ? 'block' : 'none';
    });
    var pct = Math.round((qi / 8) * 100);
    qNumEl.textContent = String(qi + 1);
    qPctEl.textContent = String(pct);
    qBarEl.style.width = pct + '%';
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ===================== STEP 1 → 2 =====================
document.getElementById('btn-step1-next').addEventListener('click', function() {
    var rev = parseFloat(document.getElementById('f-revenue').value);
    var pro = parseFloat(document.getElementById('f-profit').value);
    var sal = parseFloat(document.getElementById('f-salary').value);
    var valid = true;

    if (!rev || rev <= 0) { showFieldErr('err-revenue'); valid = false; } else { hideFieldErr('err-revenue'); }
    if (isNaN(pro) || pro < 0) { showFieldErr('err-profit'); valid = false; } else { hideFieldErr('err-profit'); }
    if (isNaN(sal) || sal < 0) { showFieldErr('err-salary'); valid = false; } else { hideFieldErr('err-salary'); }

    if (!valid) return;
    financials = { revenue: rev, profit: pro, salary: sal };
    goToStep(2);
    showQuestion(0);
});

// ===================== QUESTION NAVIGATION =====================
document.querySelectorAll('.q-next-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
        var qi = parseInt(btn.dataset.qi);
        var checked = document.querySelector('input[name="q' + qi + '"]:checked');
        if (!checked) { flashCard(btn.closest('.bg-white')); return; }
        showQuestion(qi + 1);
    });
});

var btnStep2Done = document.getElementById('btn-step2-done');
if (btnStep2Done) {
    btnStep2Done.addEventListener('click', function() {
        var qi = parseInt(btnStep2Done.dataset.qi);
        var checked = document.querySelector('input[name="q' + qi + '"]:checked');
        if (!checked) { flashCard(btnStep2Done.closest('.bg-white')); return; }
        goToStep(3);
    });
}

document.querySelectorAll('.q-prev-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
        var qi = parseInt(btn.dataset.qi);
        if (qi === 0) { goToStep(1); } else { showQuestion(qi - 1); }
    });
});

// ===================== STEP 3 BACK =====================
document.getElementById('btn-step3-back').addEventListener('click', function() {
    goToStep(2);
    showQuestion(7);
});

// ===================== LEAD FORM SUBMIT =====================
document.getElementById('lead-form').addEventListener('submit', async function(e) {
    e.preventDefault();

    // Validate text/select fields
    var fieldIds = ['lf-first', 'lf-last', 'lf-email', 'lf-phone', 'lf-company', 'lf-trade', 'lf-employees', 'lf-location'];
    var valid = true;

    fieldIds.forEach(function(id) {
        var el  = document.getElementById(id);
        var err = el.parentElement.querySelector('.lf-err') || el.closest('div').querySelector('.lf-err');
        if (!el.value.trim()) {
            if (err) err.classList.remove('hidden');
            valid = false;
        } else {
            if (err) err.classList.add('hidden');
        }
    });

    // Email format check
    var emailEl  = document.getElementById('lf-email');
    var emailErr = emailEl.parentElement.querySelector('.lf-err');
    if (emailEl.value.trim() && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailEl.value.trim())) {
        if (emailErr) emailErr.classList.remove('hidden');
        valid = false;
    }

    // Situation radio
    var situation = document.querySelector('input[name="current_situation"]:checked');
    var errSit    = document.getElementById('err-situation');
    if (!situation) { errSit.classList.remove('hidden'); valid = false; }
    else             { errSit.classList.add('hidden'); }

    if (!valid) return;

    // Calculate results now (before submission)
    var results = calculateResults();
    cachedResults = results;

    // UI: loading state
    var submitBtn     = document.getElementById('btn-step3-submit');
    var submitLabel   = document.getElementById('submit-label');
    var submitSpinner = document.getElementById('submit-spinner');
    var hsErr         = document.getElementById('err-hubspot');

    submitBtn.disabled = true;
    submitLabel.textContent = 'Submitting...';
    submitSpinner.classList.remove('hidden');
    hsErr.classList.add('hidden');

    try {
        await submitToHubSpot(results);
    } catch (err) {
        console.warn('HubSpot submission error (showing results anyway):', err);
        // Graceful degradation — show results even if HubSpot fails
    }

    submitBtn.disabled = false;
    submitLabel.textContent = 'Show My Valuation →';
    submitSpinner.classList.add('hidden');

    renderResults(results);
    goToStep(4);
});

// ===================== CALCULATIONS =====================
function calculateResults() {
    var sde        = financials.profit + financials.salary;
    var totalScore = 0;
    var qResults   = [];

    var drivers = [
        { driver: 'Owner Reliance',         service: 'Our Systems & Processes service is designed to reduce owner dependency.' },
        { driver: 'Recurring Revenue',       service: 'Our Revenue Strategy service helps you build contracted, predictable income streams.' },
        { driver: 'Systems & Processes',     service: 'Our Operational Systems service will document and systematise your key workflows.' },
        { driver: 'Team & Leadership',       service: 'Our Team & Leadership service helps you build a management structure that runs without you.' },
        { driver: 'Financial Clarity',       service: 'Our Financial Clarity service delivers real-time visibility into your numbers.' },
        { driver: 'Customer Concentration',  service: 'Our Growth & Marketing service diversifies your client base and reduces concentration risk.' },
        { driver: 'Growth & Scalability',    service: 'Our Scale & Exit service prepares your business model for sustainable growth.' },
        { driver: 'Brand & Market Position', service: 'Our Brand & Marketing service strengthens your market position and lead pipeline.' },
    ];

    for (var i = 0; i < 8; i++) {
        var checked = document.querySelector('input[name="q' + i + '"]:checked');
        var val     = checked ? parseFloat(checked.value) : 2;
        totalScore += val;
        qResults.push({ driver: drivers[i].driver, service: drivers[i].service, score: val });
    }

    // Score out of 100 (max: 8 × 12.5 = 100)
    var scoreRounded = Math.round(totalScore);
    var multiple     = 1.5 + (totalScore / 100) * 3.0;
    var valLow       = sde * (multiple * 0.9);
    var valHigh      = sde * (multiple * 1.1);

    // 3 weakest areas
    var sorted  = qResults.slice().sort(function(a, b) { return a.score - b.score; });
    var weakest = sorted.slice(0, 3);

    return { sde: sde, totalScore: totalScore, scoreRounded: scoreRounded, multiple: multiple, valLow: valLow, valHigh: valHigh, qResults: qResults, weakest: weakest };
}

// ===================== HUBSPOT SUBMISSION =====================
async function submitToHubSpot(results) {
    var url = 'https://api-ap1.hsforms.com/submissions/v3/integration/submit/' + HS_PORTAL_ID + '/' + HS_FORM_GUID;

    var fields = [
        { name: 'firstname',           value: document.getElementById('lf-first').value.trim() },
        { name: 'lastname',            value: document.getElementById('lf-last').value.trim() },
        { name: 'email',               value: document.getElementById('lf-email').value.trim() },
        { name: 'phone',               value: document.getElementById('lf-phone').value.trim() },
        { name: 'company',             value: document.getElementById('lf-company').value.trim() },
        { name: 'trade_type',          value: document.getElementById('lf-trade').value },
        { name: 'number_of_employees', value: document.getElementById('lf-employees').value },
        { name: 'state',               value: document.getElementById('lf-location').value },
        { name: 'current_situation',   value: (document.querySelector('input[name="current_situation"]:checked') || {}).value || '' },
        // Scorecard data
        { name: 'scorecard_score',         value: String(results.scoreRounded) },
        { name: 'scorecard_val_low',        value: fmt(results.valLow) },
        { name: 'scorecard_val_high',       value: fmt(results.valHigh) },
        { name: 'scorecard_weakest_areas',  value: results.weakest.map(function(w) { return w.driver; }).join(', ') },
        { name: 'scorecard_multiple',       value: results.multiple.toFixed(2) },
        { name: 'annual_revenue',           value: String(financials.revenue) },
        { name: 'annual_net_profit',        value: String(financials.profit) },
        { name: 'owner_salary_perks',       value: String(financials.salary) },
    ];

    var payload = {
        fields:  fields,
        context: { pageUri: window.location.href, pageName: 'Business Valuation Scorecard' },
    };

    var res = await fetch(url, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(payload),
    });

    if (!res.ok) throw new Error('HubSpot returned status ' + res.status);
    return res.json();
}

// ===================== RENDER RESULTS =====================
function renderResults(r) {
    document.getElementById('r-val-low').textContent   = fmt(r.valLow);
    document.getElementById('r-val-high').textContent  = fmt(r.valHigh);
    document.getElementById('r-score').textContent     = String(r.scoreRounded);
    document.getElementById('r-score-label').textContent = scoreLabel(r.scoreRounded);
    document.getElementById('r-sde').textContent       = fmt(r.sde);
    document.getElementById('r-multiple').textContent  = r.multiple.toFixed(2) + 'x';

    setTimeout(function() {
        document.getElementById('r-score-bar').style.width = r.totalScore + '%';
    }, 300);

    var list = document.getElementById('r-pathway');
    list.innerHTML = '';
    r.weakest.forEach(function(item) {
        var li = document.createElement('li');
        li.className = 'flex items-start gap-4 p-4 rounded-lg';
        li.style.background = '#F4F1EC';
        li.innerHTML =
            '<div style="width:10px;height:10px;border-radius:50%;background:#D4820A;margin-top:4px;flex-shrink:0"></div>' +
            '<div>' +
                '<p style="font-weight:600;color:#141C24;font-size:14px;margin-bottom:3px">' + item.driver + '</p>' +
                '<p style="color:#141C24;opacity:.6;font-size:14px">' + item.service + '</p>' +
            '</div>';
        list.appendChild(li);
    });

    // Cache for PDF
    window._twResults  = r;
    window._twFinancials = financials;
    window._twContact  = {
        name:    (document.getElementById('lf-first').value + ' ' + document.getElementById('lf-last').value).trim(),
        company: document.getElementById('lf-company').value.trim(),
    };
}

// ===================== PDF GENERATION =====================
document.getElementById('btn-pdf').addEventListener('click', async function() {
    var btn = document.getElementById('btn-pdf');
    btn.textContent = 'Generating PDF...';
    btn.disabled    = true;

    if (!window.jspdf) {
        await new Promise(function(resolve, reject) {
            var s    = document.createElement('script');
            s.src    = 'https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js';
            s.onload = resolve;
            s.onerror = reject;
            document.head.appendChild(s);
        });
    }

    var r       = window._twResults;
    var contact = window._twContact;
    var fin     = window._twFinancials;
    var today   = new Date().toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' });

    var doc = new window.jspdf.jsPDF({ unit: 'mm', format: 'a4' });

    var navy     = [30,  58, 95];
    var amber    = [212, 130, 10];
    var teal     = [26,  122, 110];
    var darkGrey = [80,  80,  80];
    var lightBg  = [244, 241, 236];
    var white    = [255, 255, 255];

    var W = 210, pad = 15;
    var y = 0;

    // ── Header bar ──
    doc.setFillColor.apply(doc, navy);
    doc.rect(0, 0, W, 42, 'F');

    doc.setTextColor.apply(doc, white);
    doc.setFontSize(18);
    doc.setFont('helvetica', 'bold');
    doc.text('Business Valuation Scorecard', pad, 16);

    doc.setFontSize(9);
    doc.setFont('helvetica', 'normal');
    doc.text('Prepared by TradeWise Group  ·  ' + today, pad, 25);

    if (contact.company || contact.name) {
        doc.setTextColor.apply(doc, amber);
        doc.text('Prepared for: ' + (contact.company || contact.name), pad, 34);
    }

    y = 52;

    // ── Valuation range ──
    doc.setFillColor.apply(doc, lightBg);
    doc.roundedRect(pad, y, W - pad * 2, 28, 3, 3, 'F');

    doc.setTextColor.apply(doc, amber);
    doc.setFontSize(7);
    doc.setFont('helvetica', 'bold');
    doc.text('ESTIMATED VALUATION RANGE', W / 2, y + 8, { align: 'center' });

    doc.setTextColor.apply(doc, navy);
    doc.setFontSize(20);
    doc.text(fmt(r.valLow) + '  —  ' + fmt(r.valHigh), W / 2, y + 22, { align: 'center' });

    y += 35;

    // ── Three metric boxes ──
    var boxW = 57, boxH = 24, gap = 4;
    var boxes = [
        ['RISK & QUALITY SCORE', String(r.scoreRounded) + ' / 100'],
        ["SELLER'S DISCRETIONARY EARNINGS", fmt(r.sde)],
        ['VALUATION MULTIPLE', r.multiple.toFixed(2) + 'x'],
    ];
    boxes.forEach(function(box, idx) {
        var bx = pad + idx * (boxW + gap);
        doc.setFillColor(248, 246, 242);
        doc.roundedRect(bx, y, boxW, boxH, 2, 2, 'F');
        doc.setTextColor.apply(doc, darkGrey);
        doc.setFontSize(6.5);
        doc.setFont('helvetica', 'bold');
        doc.text(box[0], bx + boxW / 2, y + 7, { align: 'center', maxWidth: boxW - 4 });
        doc.setTextColor.apply(doc, navy);
        doc.setFontSize(12);
        doc.text(String(box[1]), bx + boxW / 2, y + 18, { align: 'center' });
    });
    y += boxH + 6;

    doc.setTextColor.apply(doc, darkGrey);
    doc.setFontSize(8);
    doc.setFont('helvetica', 'italic');
    doc.text(scoreLabel(r.scoreRounded), pad, y);
    y += 10;

    // ── Divider ──
    doc.setDrawColor(220, 216, 210);
    doc.line(pad, y, W - pad, y);
    y += 8;

    // ── Pathway ──
    doc.setTextColor.apply(doc, navy);
    doc.setFontSize(12);
    doc.setFont('helvetica', 'bold');
    doc.text('Your Pathway to a More Valuable Business', pad, y);
    y += 5;

    doc.setTextColor.apply(doc, darkGrey);
    doc.setFontSize(8);
    doc.setFont('helvetica', 'normal');
    doc.text('Improving these three areas will have the greatest impact on your valuation.', pad, y);
    y += 7;

    r.weakest.forEach(function(item) {
        doc.setFillColor.apply(doc, lightBg);
        doc.roundedRect(pad, y, W - pad * 2, 20, 2, 2, 'F');

        doc.setFillColor.apply(doc, amber);
        doc.circle(pad + 6, y + 10, 2.5, 'F');

        doc.setTextColor.apply(doc, navy);
        doc.setFontSize(10);
        doc.setFont('helvetica', 'bold');
        doc.text(item.driver, pad + 12, y + 8);

        doc.setTextColor.apply(doc, darkGrey);
        doc.setFontSize(8);
        doc.setFont('helvetica', 'normal');
        doc.text(item.service, pad + 12, y + 16, { maxWidth: W - pad * 2 - 16 });

        y += 24;
    });

    y += 2;
    doc.setDrawColor(220, 216, 210);
    doc.line(pad, y, W - pad, y);
    y += 8;

    // ── Financial summary ──
    doc.setTextColor.apply(doc, navy);
    doc.setFontSize(10);
    doc.setFont('helvetica', 'bold');
    doc.text('Financial Inputs Used', pad, y);
    y += 7;

    [
        ['Annual Revenue',                         fmt(fin.revenue)],
        ['Annual Net Profit (before tax & wage)',  fmt(fin.profit)],
        ['Owner Salary & Perks',                   fmt(fin.salary)],
    ].forEach(function(row) {
        doc.setTextColor.apply(doc, darkGrey);
        doc.setFontSize(8);
        doc.setFont('helvetica', 'normal');
        doc.text(row[0] + ':', pad, y);
        doc.setTextColor.apply(doc, navy);
        doc.setFont('helvetica', 'bold');
        doc.text(row[1], W - pad, y, { align: 'right' });
        y += 6;
    });

    y += 6;

    // ── CTA box ──
    doc.setFillColor.apply(doc, navy);
    doc.roundedRect(pad, y, W - pad * 2, 30, 3, 3, 'F');

    doc.setTextColor.apply(doc, white);
    doc.setFontSize(10);
    doc.setFont('helvetica', 'bold');
    doc.text('Ready to validate these numbers?', W / 2, y + 10, { align: 'center' });

    doc.setFontSize(8);
    doc.setFont('helvetica', 'normal');
    doc.text('Book a free 30-minute Valuation Debrief: meetings.hubspot.com/tradewise', W / 2, y + 19, { align: 'center' });
    doc.setTextColor(255, 255, 255);
    doc.setFontSize(7);
    doc.text('No obligation. No jargon. Just clarity.', W / 2, y + 26, { align: 'center' });

    y += 36;

    // ── Disclaimer ──
    doc.setTextColor(180, 180, 180);
    doc.setFontSize(6.5);
    doc.setFont('helvetica', 'italic');
    var disclaimer = 'Disclaimer: This report provides an indicative estimate only and does not constitute a formal business valuation, financial advice, legal advice, or investment advice. Results are based solely on the information provided and do not account for market conditions, due diligence findings, buyer appetite, or other factors that influence actual sale outcomes. TradeWise Group Pty Ltd makes no representation or warranty as to the accuracy of these estimates. You should seek independent advice from a qualified business valuer, accountant, and/or legal adviser before making any decisions relating to the sale or transfer of your business.';
    var lines = doc.splitTextToSize(disclaimer, W - pad * 2);
    doc.text(lines, pad, y);

    // ── Footer ──
    doc.setFillColor.apply(doc, navy);
    doc.rect(0, 285, W, 12, 'F');
    doc.setTextColor.apply(doc, white);
    doc.setFontSize(7);
    doc.setFont('helvetica', 'normal');
    doc.text('TradeWise Group  |  tradewisegroup.com.au', pad, 292);
    doc.text('Confidential — for ' + (contact.name || contact.company || 'client') + ' only', W - pad, 292, { align: 'right' });

    doc.save('tradewise-valuation-scorecard.pdf');

    btn.innerHTML = '<svg style="width:16px;height:16px;display:inline;margin-right:6px" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>Or download your results as a PDF';
    btn.disabled = false;
});

// ===================== RETAKE =====================
document.getElementById('btn-retake').addEventListener('click', function() {
    document.querySelectorAll('input[type="radio"]').forEach(function(r) { r.checked = false; });
    document.getElementById('f-revenue').value = '';
    document.getElementById('f-profit').value  = '';
    document.getElementById('f-salary').value  = '';
    document.getElementById('lead-form').reset();
    document.getElementById('r-score-bar').style.width = '0%';
    financials    = { revenue: 0, profit: 0, salary: 0 };
    cachedResults = null;
    goToStep(1);
    showQuestion(0);
});

// ===================== HELPERS =====================
function fmt(n) {
    return new Intl.NumberFormat('en-AU', { style: 'currency', currency: 'AUD', maximumFractionDigits: 0 }).format(n || 0);
}

function scoreLabel(s) {
    if (s <= 25) return 'High Risk — significant improvements needed before exit.';
    if (s <= 50) return 'Developing — good foundations, but key gaps reduce your multiple.';
    if (s <= 75) return 'Progressing — above average, with clear upside available.';
    return 'Exit-Ready — your business is well-positioned for a strong sale.';
}

function showFieldErr(id) { var el = document.getElementById(id); if (el) el.classList.remove('hidden'); }
function hideFieldErr(id) { var el = document.getElementById(id); if (el) el.classList.add('hidden'); }

function flashCard(el) {
    if (!el) return;
    el.classList.add('ring-2', 'ring-red-400');
    setTimeout(function() { el.classList.remove('ring-2', 'ring-red-400'); }, 1500);
}
</script>
